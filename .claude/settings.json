{
  "enabledPlugins": {
    "playwright@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/astro-check-on-edit.sh",
            "timeout": 90
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/stop-checks.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": ".claude/hooks/detect-stale-dev-servers.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
