{
  "name": "timeline-dsl-site",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "astro dev",
    "fetch:releases": "node scripts/fetch-github-releases.mjs",
    "fetch:repo-stats": "node scripts/fetch-github-repo-stats.mjs",
    "smoke:wasm": "node scripts/smoke-tdsl-wasm.mjs",
    "smoke:playground": "node scripts/smoke-playground.mjs",
    "smoke:playground:browser": "node scripts/smoke-playground.mjs --browser",
    "smoke:i18n": "node scripts/smoke-i18n.mjs",
    "smoke:i18n:browser": "node scripts/smoke-i18n.mjs --browser",
    "smoke:seo": "node scripts/smoke-seo.mjs",
    "smoke:a11y": "node scripts/smoke-a11y.mjs",
    "bundle-size": "node scripts/bundle-size.mjs",
    "lhci": "lhci autorun --config=./lighthouserc.cjs",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "build": "pnpm smoke:wasm && astro check && astro build",
    "check": "pnpm lint && pnpm format:check && pnpm test:unit && pnpm build && pnpm bundle-size",
    "check:full": "node scripts/check-full.mjs",
    "preview": "astro preview",
    "prepare": "lefthook install",
    "lint": "biome lint .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write . && prettier --write \"**/*.{astro,md,mdx}\"",
    "format:check": "biome format . && prettier --check \"**/*.{astro,md,mdx}\""
  },
  "dependencies": {
    "@astrojs/markdown-remark": "7.2.1",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/starlight": "0.41.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "astro": "7.1.1",
    "rehype-sanitize": "6.0.0",
    "starlight-llms-txt": "^0.11.0",
    "starlight-md-txt": "^0.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.5.4",
    "@lhci/cli": "^0.15.1",
    "@resvg/resvg-js": "^2.6.2",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.10",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "shiki": "^4.2.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.8"
  }
}
