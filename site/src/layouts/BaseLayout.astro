---
import SocialMeta from "../components/SocialMeta.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { graphLd, organizationLd, webPageLd } from "../lib/seo-jsonld";
import type { Locale } from "../i18n";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  pathname: string;
  locale?: string;
  ogImagePath?: string;
  version?: string | null;
  shellClass?: string;
  showAlternates?: boolean;
  extraJsonLd?: Record<string, unknown>[];
}

const {
  title,
  description,
  pathname,
  locale = "ja",
  ogImagePath,
  version,
  shellClass,
  showAlternates = true,
  extraJsonLd = [],
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://timeline-dsl.pages.dev");
// pathname が "/en/" で始まる場合はプレフィックスを取り除く
const rootPath = pathname.startsWith("/en/") ? pathname.slice(3) : pathname;
const jaUrl = new URL(rootPath, siteUrl).toString();
const enUrl = new URL(`/en${rootPath}`, siteUrl).toString();
const canonicalUrl = locale === "en" ? enUrl : jaUrl;

const seoLocale: Locale = locale === "en" ? "en" : "ja";
const jsonLdGraph = graphLd([
  organizationLd(siteUrl),
  webPageLd({ siteUrl, pathname, title, description, locale: seoLocale }),
  ...extraJsonLd,
]);
---

<!doctype html>
<html lang={Astro.currentLocale ?? locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <SocialMeta
      title={title}
      description={description}
      pathname={pathname}
      imagePath={ogImagePath}
      locale={locale}
    />
    <link rel="canonical" href={canonicalUrl} />
    {showAlternates && (
      <>
        <link rel="alternate" hreflang="ja" href={jaUrl} />
        <link rel="alternate" hreflang="en" href={enUrl} />
        <link rel="alternate" hreflang="x-default" href={jaUrl} />
      </>
    )}
    <script is:inline type="application/ld+json" set:html={jsonLdGraph} />
    <title>{title}</title>
  </head>
  <body>
    <div class:list={["page-shell", shellClass]}>
      <SiteHeader currentPath={pathname} />
      <slot />
      <SiteFooter currentPath={pathname} version={version} />
    </div>
    <slot name="body-end" />
  </body>
</html>
