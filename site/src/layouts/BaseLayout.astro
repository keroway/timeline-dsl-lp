---
import SocialMeta from "../components/SocialMeta.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { graphLd, organizationLd, webPageLd } from "../lib/seo-jsonld";
import { getSiteUrl } from "../lib/site";
import { getT, type Locale } from "../i18n";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  pathname: string;
  locale?: string;
  ogImagePath?: string;
  version?: string | null;
  shellClass?: string;
  showAlternates?: boolean;
  extraJsonLd?: Record<string, unknown>[];
}

const {
  title,
  description,
  pathname,
  locale = "ja",
  ogImagePath,
  version,
  shellClass,
  showAlternates = true,
  extraJsonLd = [],
} = Astro.props;

const siteUrl = getSiteUrl(Astro);
// pathname が "/en/" で始まる場合はプレフィックスを取り除く
const rootPath = pathname.startsWith("/en/") ? pathname.slice(3) : pathname;
const jaUrl = new URL(rootPath, siteUrl).toString();
const enUrl = new URL(`/en${rootPath}`, siteUrl).toString();
const canonicalUrl = locale === "en" ? enUrl : jaUrl;

const seoLocale: Locale = locale === "en" ? "en" : "ja";
const t = getT(seoLocale);
const jsonLdGraph = graphLd([
  organizationLd(siteUrl),
  webPageLd({ siteUrl, pathname, title, description, locale: seoLocale }),
  ...extraJsonLd,
]);
---

<!doctype html>
<html lang={Astro.currentLocale ?? locale}>
  <head>
    {
      /* テーマの FOUC 防止（#431）。Starlight の ThemeProvider と同じ localStorage キー
        (`starlight-theme`) を初回描画前に同期的に読み、<html> の data-theme を初期化する。
        失敗しても具合は悪いだけ（OS 設定にフォールバック）なので try/catch で黙す。 */
    }
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem("starlight-theme");
          const theme =
            stored === "light" || stored === "dark"
              ? stored
              : matchMedia("(prefers-color-scheme: light)").matches
                ? "light"
                : "dark";
          document.documentElement.dataset.theme = theme;
        } catch {
          /* localStorage 無効環境では data-theme 未設定のままにし、CSS の
             @media (prefers-color-scheme: dark) フォールバックに任せる。 */
        }
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <SocialMeta
      title={title}
      description={description}
      pathname={pathname}
      imagePath={ogImagePath}
      locale={locale}
    />
    <link rel="canonical" href={canonicalUrl} />
    {
      showAlternates && (
        <>
          <link rel="alternate" hreflang="ja" href={jaUrl} />
          <link rel="alternate" hreflang="en" href={enUrl} />
          <link rel="alternate" hreflang="x-default" href={jaUrl} />
        </>
      )
    }
    <script is:inline type="application/ld+json" set:html={jsonLdGraph} />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">{t("a11y.skip_link")}</a>
    <div class:list={["page-shell", shellClass]}>
      <SiteHeader currentPath={pathname} />
      <slot />
      <SiteFooter currentPath={pathname} version={version} />
    </div>
    <slot name="body-end" />
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    padding: 0.5rem 1rem;
    background: var(--color-accent, #000);
    color: #fff;
    border-radius: 0 0 4px 4px;
    font-size: 0.9rem;
    text-decoration: none;
    transition: top 0.1s;
  }
  .skip-link:focus {
    top: 0;
  }
</style>
