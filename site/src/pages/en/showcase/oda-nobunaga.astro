---
import ShowcasePage from "../../../components/ShowcasePage.astro";
import { getT } from "../../../i18n/index";

const locale = "en" as const;
const t = getT(locale);

const source = `timeline "The Life of Oda Nobunaga (1534–1582)" {
    title "The Life of Oda Nobunaga";
    unit year;
    range 1534..1583;
    calendar proleptic_gregorian;
}

lane "Life" as life { kind custom; order 10; }
lane "Battles" as battle { kind custom; order 20; }
lane "Unification" as politics { kind custom; order 30; }

span life 1534..1582 "Nobunaga's Life" {};
event life 1534 "Born (Nagoya Castle, Owari Province)" {};
event life 1551 "Inherited the clan" {};
event life 1582 "Honnō-ji Incident (age 48)" {};

event battle 1560 "Battle of Okehazama (defeated Imagawa Yoshimoto)" {};
event battle 1570 "Battle of Anegawa" {};
event battle 1573 "Battle of Makishima (exiled Ashikaga Yoshiaki)" {};
event battle 1575 "Battle of Nagashino (volley fire tactics)" {};
event battle 1580 "End of the Ishiyama Hongan-ji War" {};

event politics 1559 "Unified Owari Province" {};
event politics 1568 "Marched on Kyoto, installed Ashikaga Yoshiaki" {};
event politics 1573 "Fall of the Muromachi Shogunate" {};
event politics 1576 "Began construction of Azuchi Castle" {};
event politics 1580 "Sōbuji Edict" {};
`;
---

<ShowcasePage
  locale={locale}
  h1="The Life of Oda Nobunaga"
  title="The Life of Oda Nobunaga — Showcase | Timeline DSL"
  description="A Timeline DSL timeline covering the life of Oda Nobunaga (1534–1582), the dominant warlord of Japan's Sengoku era. Three lanes — Life, Battles, and Unification — provide a 48-year overview."
  pathname="/en/showcase/oda-nobunaga/"
  source={source}
  caption="Timeline of Oda Nobunaga's life. Click to open in the Playground and edit or customize the DSL."
  breadcrumbs={[
    { name: "Timeline DSL", url: "/en/" },
    { name: "Showcase", url: "/en/showcase/" },
    { name: "The Life of Oda Nobunaga", url: "/en/showcase/oda-nobunaga/" },
  ]}
  meta={[
    { label: t("showcase.card.period"), value: "1534 – 1582 (49 years)" },
    { label: t("showcase.card.lanes"), value: "Life / Battles / Unification" },
    { label: t("showcase.card.events"), value: "13" },
  ]}
  notesHeading="Timeline DSL in action"
>
  <ul>
    <li>
      <code>span</code> covers Nobunaga's entire lifetime, while
      <code>event</code> records individual milestones — both coexist in the same timeline.
    </li>
    <li>
      Three <code>lane</code> declarations let you read parallel threads of the same era side by side:
      personal life, military campaigns, and political moves.
    </li>
    <li>
      <code>unit year</code> + <code>calendar proleptic_gregorian</code> gives a clean Western calendar
      display ideal for historical timelines.
    </li>
  </ul>
  <p>
    See the <a href="/en/docs/">syntax reference</a> to build your own timeline in minutes.
  </p>
</ShowcasePage>
