---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import TimelineEmbed from "../../../components/TimelineEmbed.astro";
import { breadcrumbLd } from "../../../lib/seo-jsonld";

const source = `timeline "The Life of Oda Nobunaga (1534–1582)" {
    title "The Life of Oda Nobunaga";
    unit year;
    range 1534..1583;
    calendar proleptic_gregorian;
}

lane "Life" as life { kind custom; order 10; }
lane "Battles" as battle { kind custom; order 20; }
lane "Unification" as politics { kind custom; order 30; }

span life 1534..1582 "Nobunaga's Life" {};
event life 1534 "Born (Nagoya Castle, Owari Province)" {};
event life 1551 "Inherited the clan" {};
event life 1582 "Honnō-ji Incident (age 48)" {};

event battle 1560 "Battle of Okehazama (defeated Imagawa Yoshimoto)" {};
event battle 1570 "Battle of Anegawa" {};
event battle 1573 "Battle of Makishima (exiled Ashikaga Yoshiaki)" {};
event battle 1575 "Battle of Nagashino (volley fire tactics)" {};
event battle 1580 "End of the Ishiyama Hongan-ji War" {};

event politics 1559 "Unified Owari Province" {};
event politics 1568 "Marched on Kyoto, installed Ashikaga Yoshiaki" {};
event politics 1573 "Fall of the Muromachi Shogunate" {};
event politics 1576 "Began construction of Azuchi Castle" {};
event politics 1580 "Sōbuji Edict" {};
`;

const siteUrl = Astro.site ?? new URL("https://timeline-dsl.pages.dev");
const breadcrumb = breadcrumbLd(
  [
    { name: "Timeline DSL", url: "/en/" },
    { name: "Showcase", url: "/en/showcase/" },
    { name: "The Life of Oda Nobunaga", url: "/en/showcase/oda-nobunaga/" },
  ],
  siteUrl,
);
---

<BaseLayout
  title="The Life of Oda Nobunaga — Showcase | Timeline DSL"
  description="A Timeline DSL timeline covering the life of Oda Nobunaga (1534–1582), the dominant warlord of Japan's Sengoku era. Three lanes — Life, Battles, and Unification — provide a 48-year overview."
  pathname="/en/showcase/oda-nobunaga/"
  locale="en"
  extraJsonLd={[breadcrumb]}
>
  <main id="main-content" class="showcase-page">
    <div class="showcase-inner">
      <nav class="showcase-breadcrumb" aria-label="Breadcrumb">
        <a href="/en/showcase/">Showcase</a>
        <span aria-hidden="true"> / </span>
        <span aria-current="page">The Life of Oda Nobunaga</span>
      </nav>

      <header class="showcase-header">
        <h1 class="showcase-title">The Life of Oda Nobunaga</h1>
        <p class="showcase-description">
          A Timeline DSL timeline covering the life of Oda Nobunaga (1534–1582),
          the dominant warlord of Japan's Sengoku era.
          Three lanes — Life, Battles, and Unification — provide a 48-year overview.
        </p>
        <dl class="showcase-meta">
          <div>
            <dt>Period</dt>
            <dd>1534 – 1582 (49 years)</dd>
          </div>
          <div>
            <dt>Lanes</dt>
            <dd>Life / Battles / Unification</dd>
          </div>
          <div>
            <dt>Events</dt>
            <dd>13</dd>
          </div>
        </dl>
      </header>

      <TimelineEmbed
        source={source}
        caption="Timeline of Oda Nobunaga's life. Click to open in the Playground and edit or customize the DSL."
      />

      <section class="showcase-notes">
        <h2>Timeline DSL in action</h2>
        <ul>
          <li>
            <code>span</code> covers Nobunaga's entire lifetime, while
            <code>event</code> records individual milestones — both coexist in the same timeline.
          </li>
          <li>
            Three <code>lane</code> declarations let you read parallel threads of the same era
            side by side: personal life, military campaigns, and political moves.
          </li>
          <li>
            <code>unit year</code> + <code>calendar proleptic_gregorian</code> gives a clean
            Western calendar display ideal for historical timelines.
          </li>
        </ul>
        <p>
          See the <a href="/en/docs/">syntax reference</a> to build your own timeline in minutes.
        </p>
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .showcase-page {
    padding: 3rem 1.5rem 5rem;
  }

  .showcase-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .showcase-breadcrumb {
    font-size: 0.875rem;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .showcase-breadcrumb a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .showcase-breadcrumb a:hover {
    text-decoration: underline;
  }

  .showcase-header {
    margin-bottom: 2rem;
  }

  .showcase-title {
    font-size: 2rem;
    font-weight: 700;
    font-family: var(--font-display);
    color: var(--color-ink);
    margin: 0 0 0.75rem;
    line-height: 1.25;
  }

  .showcase-description {
    font-size: 1.05rem;
    color: var(--color-muted);
    line-height: var(--line-height-base);
    margin: 0 0 1.25rem;
  }

  .showcase-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin: 0;
    padding: 1rem 1.25rem;
    background: var(--color-panel);
    border-radius: 6px;
    border: 1px solid var(--color-line);
    font-size: 0.875rem;
  }

  .showcase-meta div {
    display: flex;
    gap: 0.4rem;
  }

  .showcase-meta dt {
    color: var(--color-muted);
    font-weight: 500;
  }

  .showcase-meta dt::after {
    content: ":";
  }

  .showcase-meta dd {
    margin: 0;
    color: var(--color-ink);
  }

  .showcase-notes {
    margin-top: 2.5rem;
    padding: 1.5rem;
    background: var(--color-panel);
    border-radius: 8px;
    border: 1px solid var(--color-line);
  }

  .showcase-notes h2 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 1rem;
    color: var(--color-ink);
  }

  .showcase-notes ul {
    margin: 0 0 1rem;
    padding-left: 1.5rem;
    color: var(--color-muted);
    line-height: var(--line-height-base);
  }

  .showcase-notes li {
    margin-bottom: 0.5rem;
  }

  .showcase-notes li:last-child {
    margin-bottom: 0;
  }

  .showcase-notes code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-bg);
    padding: 0.1em 0.3em;
    border-radius: 3px;
    border: 1px solid var(--color-line);
  }

  .showcase-notes p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .showcase-notes a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .showcase-notes a:hover {
    text-decoration: underline;
  }
</style>
