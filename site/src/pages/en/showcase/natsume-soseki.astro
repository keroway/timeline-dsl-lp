---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import TimelineEmbed from "../../../components/TimelineEmbed.astro";
import { breadcrumbLd } from "../../../lib/seo-jsonld";

const source = `timeline "The Life of Natsume Soseki (1867–1916)" {
    title "The Life of Natsume Soseki";
    unit year;
    range 1867..1917;
    calendar proleptic_gregorian;
}

lane "Life" as life { kind custom; order 10; }
lane "Career & Teaching" as career { kind custom; order 20; }
lane "Works" as works { kind custom; order 30; }

span life 1867..1916 "Soseki's Life" {};
event life 1867 "Born in Ushigome, Edo (given name: Kinnosuke)" {};
event life 1888 "Enrolled in the First Higher Middle School" {};
event life 1896 "Married Nakane Kyoko" {};
event life 1907 "Joined the Asahi Shimbun (became a professional writer)" {};
event life 1910 "Near-death illness in Shuzenji" {};
event life 1916 "Died of stomach ulcer (age 49)" {};

event career 1890 "Enrolled in the English Literature dept., Imperial University" {};
event career 1893 "Graduated; became a teacher at the Tokyo Higher Normal School" {};
event career 1895 "English teacher at Matsuyama Middle School (setting of Botchan)" {};
span career 1900..1903 "Studied in London (Ministry of Education scholarship)" {};
event career 1903 "Lecturer in English Literature, Tokyo Imperial University" {};

event works 1905 "Began serializing 'I Am a Cat'" {};
event works 1906 "'Botchan', 'Kusamakura'" {};
event works 1908 "'Sanshiro'" {};
event works 1909 "'And Then'" {};
event works 1910 "'The Gate'" {};
event works 1914 "'Kokoro'" {};
event works 1915 "'Grass on the Wayside'" {};
event works 1916 "'Light and Darkness' (unfinished, final work)" {};
`;

const siteUrl = Astro.site ?? new URL("https://timeline-dsl.pages.dev");
const breadcrumb = breadcrumbLd(
  [
    { name: "Timeline DSL", url: "/en/" },
    { name: "Showcase", url: "/en/showcase/" },
    { name: "The Life of Natsume Soseki", url: "/en/showcase/natsume-soseki/" },
  ],
  siteUrl,
);
---

<BaseLayout
  title="The Life of Natsume Soseki — Showcase | Timeline DSL"
  description="A Timeline DSL timeline covering the life and literary works of Natsume Soseki (1867–1916), active from the Meiji to Taisho era. Three lanes — Life, Career & Teaching, and Works — trace 49 years of milestones."
  pathname="/en/showcase/natsume-soseki/"
  locale="en"
  extraJsonLd={[breadcrumb]}
>
  <main id="main-content" class="showcase-page">
    <div class="showcase-inner">
      <nav class="showcase-breadcrumb" aria-label="Breadcrumb">
        <a href="/en/showcase/">Showcase</a>
        <span aria-hidden="true"> / </span>
        <span aria-current="page">The Life of Natsume Soseki</span>
      </nav>

      <header class="showcase-header">
        <h1 class="showcase-title">The Life of Natsume Soseki</h1>
        <p class="showcase-description">
          A Timeline DSL timeline covering the life and literary works of Natsume Soseki
          (1867–1916), active from the Meiji to Taisho era. Three lanes — Life, Career &amp;
          Teaching, and Works — trace 49 years of milestones and major publications.
        </p>
        <dl class="showcase-meta">
          <div>
            <dt>Period</dt>
            <dd>1867 – 1916 (49 years)</dd>
          </div>
          <div>
            <dt>Lanes</dt>
            <dd>Life / Career &amp; Teaching / Works</dd>
          </div>
          <div>
            <dt>Events</dt>
            <dd>20</dd>
          </div>
        </dl>
      </header>

      <TimelineEmbed
        source={source}
        caption="Timeline of Natsume Soseki's life. Click to open in the Playground and edit or customize the DSL."
      />

      <section class="showcase-notes">
        <h2>Timeline DSL in action</h2>
        <ul>
          <li>
            <code>span</code> covers both his entire lifetime (1867–1916) and the London study period
            (1900–1903), showing how short- and long-running periods can coexist in one timeline.
          </li>
          <li>
            Three <code>lane</code> declarations let you correlate career turning points with publication
            dates at a glance (e.g., major novels cluster after joining the Asahi Shimbun).
          </li>
          <li>
            <code>unit year</code> + <code>calendar proleptic_gregorian</code> unifies mixed Japanese-era
            and Western-year sources into a clean Western calendar display.
          </li>
        </ul>
        <p>
          See the <a href="/en/docs/">syntax reference</a> to build your own timeline in minutes.
        </p>
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .showcase-page {
    padding: 3rem 1.5rem 5rem;
  }

  .showcase-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .showcase-breadcrumb {
    font-size: 0.875rem;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .showcase-breadcrumb a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .showcase-breadcrumb a:hover {
    text-decoration: underline;
  }

  .showcase-header {
    margin-bottom: 2rem;
  }

  .showcase-title {
    font-size: 2rem;
    font-weight: 700;
    font-family: var(--font-display);
    color: var(--color-ink);
    margin: 0 0 0.75rem;
    line-height: 1.25;
  }

  .showcase-description {
    font-size: 1.05rem;
    color: var(--color-muted);
    line-height: var(--line-height-base);
    margin: 0 0 1.25rem;
  }

  .showcase-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin: 0;
    padding: 1rem 1.25rem;
    background: var(--color-panel);
    border-radius: 6px;
    border: 1px solid var(--color-line);
    font-size: 0.875rem;
  }

  .showcase-meta div {
    display: flex;
    gap: 0.4rem;
  }

  .showcase-meta dt {
    color: var(--color-muted);
    font-weight: 500;
  }

  .showcase-meta dt::after {
    content: ":";
  }

  .showcase-meta dd {
    margin: 0;
    color: var(--color-ink);
  }

  .showcase-notes {
    margin-top: 2.5rem;
    padding: 1.5rem;
    background: var(--color-panel);
    border-radius: 8px;
    border: 1px solid var(--color-line);
  }

  .showcase-notes h2 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 1rem;
    color: var(--color-ink);
  }

  .showcase-notes ul {
    margin: 0 0 1rem;
    padding-left: 1.5rem;
    color: var(--color-muted);
    line-height: var(--line-height-base);
  }

  .showcase-notes li {
    margin-bottom: 0.5rem;
  }

  .showcase-notes li:last-child {
    margin-bottom: 0;
  }

  .showcase-notes code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-bg);
    padding: 0.1em 0.3em;
    border-radius: 3px;
    border: 1px solid var(--color-line);
  }

  .showcase-notes p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .showcase-notes a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .showcase-notes a:hover {
    text-decoration: underline;
  }
</style>
