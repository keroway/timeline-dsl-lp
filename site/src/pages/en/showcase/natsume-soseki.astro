---
import ShowcasePage from "../../../components/ShowcasePage.astro";
import { getT } from "../../../i18n/index";

const locale = "en" as const;
const t = getT(locale);

const source = `timeline "The Life of Natsume Soseki (1867–1916)" {
    title "The Life of Natsume Soseki";
    unit year;
    range 1867..1917;
    calendar proleptic_gregorian;
}

lane "Life" as life { kind custom; order 10; }
lane "Career & Teaching" as career { kind custom; order 20; }
lane "Works" as works { kind custom; order 30; }

span life 1867..1916 "Soseki's Life" {};
event life 1867 "Born in Ushigome, Edo (given name: Kinnosuke)" {};
event life 1888 "Enrolled in the First Higher Middle School" {};
event life 1896 "Married Nakane Kyoko" {};
event life 1907 "Joined the Asahi Shimbun (became a professional writer)" {};
event life 1910 "Near-death illness in Shuzenji" {};
event life 1916 "Died of stomach ulcer (age 49)" {};

event career 1890 "Enrolled in the English Literature dept., Imperial University" {};
event career 1893 "Graduated; became a teacher at the Tokyo Higher Normal School" {};
event career 1895 "English teacher at Matsuyama Middle School (setting of Botchan)" {};
span career 1900..1903 "Studied in London (Ministry of Education scholarship)" {};
event career 1903 "Lecturer in English Literature, Tokyo Imperial University" {};

event works 1905 "Began serializing 'I Am a Cat'" {};
event works 1906 "'Botchan', 'Kusamakura'" {};
event works 1908 "'Sanshiro'" {};
event works 1909 "'And Then'" {};
event works 1910 "'The Gate'" {};
event works 1914 "'Kokoro'" {};
event works 1915 "'Grass on the Wayside'" {};
event works 1916 "'Light and Darkness' (unfinished, final work)" {};
`;
---

<ShowcasePage
  locale={locale}
  h1="The Life of Natsume Soseki"
  title="The Life of Natsume Soseki — Showcase | Timeline DSL"
  description="A Timeline DSL timeline covering the life and literary works of Natsume Soseki (1867–1916), active from the Meiji to Taisho era. Three lanes — Life, Career & Teaching, and Works — trace 49 years of milestones."
  pathname="/en/showcase/natsume-soseki/"
  source={source}
  caption="Timeline of Natsume Soseki's life. Click to open in the Playground and edit or customize the DSL."
  breadcrumbs={[
    { name: "Timeline DSL", url: "/en/" },
    { name: "Showcase", url: "/en/showcase/" },
    { name: "The Life of Natsume Soseki", url: "/en/showcase/natsume-soseki/" },
  ]}
  meta={[
    { label: t("showcase.card.period"), value: "1867 – 1916 (49 years)" },
    { label: t("showcase.card.lanes"), value: "Life / Career & Teaching / Works" },
    { label: t("showcase.card.events"), value: "20" },
  ]}
  notesHeading="Timeline DSL in action"
>
  <ul>
    <li>
      <code>span</code> covers both his entire lifetime (1867–1916) and the London study period (1900–1903),
      showing how short- and long-running periods can coexist in one timeline.
    </li>
    <li>
      Three <code>lane</code> declarations let you correlate career turning points with publication dates
      at a glance (e.g., major novels cluster after joining the Asahi Shimbun).
    </li>
    <li>
      <code>unit year</code> + <code>calendar proleptic_gregorian</code> unifies mixed Japanese-era and
      Western-year sources into a clean Western calendar display.
    </li>
  </ul>
  <p>
    See the <a href="/en/docs/">syntax reference</a> to build your own timeline in minutes.
  </p>
</ShowcasePage>
