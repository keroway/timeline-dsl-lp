---
import ShowcasePage from "../../components/ShowcasePage.astro";
import { getT } from "../../i18n/index";

const locale = "ja" as const;
const t = getT(locale);

const source = `timeline "夏目漱石の生涯 (1867–1916)" {
    title "夏目漱石の生涯";
    unit year;
    range 1867..1917;
    calendar proleptic_gregorian;
}

lane "生涯" as life { kind custom; order 10; }
lane "学業・教職" as career { kind custom; order 20; }
lane "作品" as works { kind custom; order 30; }

span life 1867..1916 "漱石の生涯" {};
event life 1867 "牛込馬場下横町に誕生（本名 金之助）" {};
event life 1888 "第一高等中学校予科入学" {};
event life 1896 "中根鏡子と結婚" {};
event life 1907 "朝日新聞社入社（職業作家へ）" {};
event life 1910 "修善寺の大患" {};
event life 1916 "胃潰瘍で死去（享年 49）" {};

event career 1890 "帝国大学英文科入学" {};
event career 1893 "帝国大学卒業・東京高等師範学校教師" {};
event career 1895 "松山中学校英語教師（坊っちゃんの舞台）" {};
span career 1900..1903 "ロンドン留学（文部省給費）" {};
event career 1903 "東京帝国大学英文科講師" {};

event works 1905 "「吾輩は猫である」連載開始" {};
event works 1906 "「坊っちゃん」「草枕」" {};
event works 1908 "「三四郎」" {};
event works 1909 "「それから」" {};
event works 1910 "「門」" {};
event works 1914 "「こころ」" {};
event works 1915 "「道草」" {};
event works 1916 "「明暗」（絶筆・未完）" {};
`;
---

<ShowcasePage
  locale={locale}
  h1="夏目漱石の生涯"
  title="夏目漱石の生涯 — Showcase | Timeline DSL"
  description="Timeline DSL で記述した夏目漱石の生涯年表。生涯・学業教職・作品の 3 レーン構成で 1867 年から 1916 年を俯瞰する。"
  pathname="/showcase/natsume-soseki/"
  source={source}
  caption="夏目漱石の生涯年表。Playground でクリックして DSL を編集・カスタマイズできます。"
  breadcrumbs={[
    { name: "Timeline DSL", url: "/" },
    { name: "Showcase", url: "/showcase/" },
    { name: "夏目漱石の生涯", url: "/showcase/natsume-soseki/" },
  ]}
  meta={[
    { label: t("showcase.card.period"), value: "1867 〜 1916 年（49 年間）" },
    { label: t("showcase.card.lanes"), value: "生涯 / 学業・教職 / 作品" },
    { label: t("showcase.card.events"), value: "20" },
  ]}
  notesHeading="Timeline DSL の使い所"
>
  <ul>
    <li>
      <code>span</code> で生涯全体（1867–1916）とロンドン留学期間（1900–1903）の 両方を表現し、短期と長期の継続期間を同じ年表に同居させられます。
    </li>
    <li>
      <code>lane</code> を 3 つに分けることで、職業生活の節目と作品発表の時期を 視覚的に対応付けて読み解けます（例:
      朝日新聞入社後に長編連載が集中する流れ）。
    </li>
    <li>
      <code>unit year</code> + <code>calendar proleptic_gregorian</code> で 和暦・西暦混在の歴史年表を、シンプルな西暦表示に統一できます。
    </li>
  </ul>
  <p>
    <a href="/docs/">文法リファレンス</a> を見れば、 自分の年表を数分で作成できます。
  </p>
</ShowcasePage>
