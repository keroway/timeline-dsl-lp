---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TimelineEmbed from "../../components/TimelineEmbed.astro";
import { breadcrumbLd } from "../../lib/seo-jsonld";

const source = `timeline "夏目漱石の生涯 (1867–1916)" {
    title "夏目漱石の生涯";
    unit year;
    range 1867..1917;
    calendar proleptic_gregorian;
}

lane "生涯" as life { kind custom; order 10; }
lane "学業・教職" as career { kind custom; order 20; }
lane "作品" as works { kind custom; order 30; }

span life 1867..1916 "漱石の生涯" {};
event life 1867 "牛込馬場下横町に誕生（本名 金之助）" {};
event life 1888 "第一高等中学校予科入学" {};
event life 1896 "中根鏡子と結婚" {};
event life 1907 "朝日新聞社入社（職業作家へ）" {};
event life 1910 "修善寺の大患" {};
event life 1916 "胃潰瘍で死去（享年 49）" {};

event career 1890 "帝国大学英文科入学" {};
event career 1893 "帝国大学卒業・東京高等師範学校教師" {};
event career 1895 "松山中学校英語教師（坊っちゃんの舞台）" {};
span career 1900..1903 "ロンドン留学（文部省給費）" {};
event career 1903 "東京帝国大学英文科講師" {};

event works 1905 "「吾輩は猫である」連載開始" {};
event works 1906 "「坊っちゃん」「草枕」" {};
event works 1908 "「三四郎」" {};
event works 1909 "「それから」" {};
event works 1910 "「門」" {};
event works 1914 "「こころ」" {};
event works 1915 "「道草」" {};
event works 1916 "「明暗」（絶筆・未完）" {};
`;

const siteUrl = Astro.site ?? new URL("https://timeline-dsl.pages.dev");
const breadcrumb = breadcrumbLd(
  [
    { name: "Timeline DSL", url: "/" },
    { name: "Showcase", url: "/showcase/" },
    { name: "夏目漱石の生涯", url: "/showcase/natsume-soseki/" },
  ],
  siteUrl,
);
---

<BaseLayout
  title="夏目漱石の生涯 — Showcase | Timeline DSL"
  description="Timeline DSL で記述した夏目漱石の生涯年表。生涯・学業教職・作品の 3 レーン構成で 1867 年から 1916 年を俯瞰する。"
  pathname="/showcase/natsume-soseki/"
  locale="ja"
  extraJsonLd={[breadcrumb]}
>
  <main id="main-content" class="showcase-page">
    <div class="showcase-inner">
      <nav class="showcase-breadcrumb" aria-label="パンくずリスト">
        <a href="/showcase/">Showcase</a>
        <span aria-hidden="true"> / </span>
        <span aria-current="page">夏目漱石の生涯</span>
      </nav>

      <header class="showcase-header">
        <h1 class="showcase-title">夏目漱石の生涯</h1>
        <p class="showcase-description">
          明治から大正にかけて活躍した文豪・夏目漱石（1867–1916）の生涯を Timeline DSL
          で表現した年表です。生涯・学業教職・作品の 3 レーンで、 49
          年間の足跡と主要作品の発表時期を俯瞰します。
        </p>
        <dl class="showcase-meta">
          <div>
            <dt>期間</dt>
            <dd>1867 〜 1916 年（49 年間）</dd>
          </div>
          <div>
            <dt>レーン</dt>
            <dd>生涯 / 学業・教職 / 作品</dd>
          </div>
          <div>
            <dt>イベント数</dt>
            <dd>20</dd>
          </div>
        </dl>
      </header>

      <TimelineEmbed
        source={source}
        caption="夏目漱石の生涯年表。Playground でクリックして DSL を編集・カスタマイズできます。"
      />

      <section class="showcase-notes">
        <h2>Timeline DSL の使い所</h2>
        <ul>
          <li>
            <code>span</code> で生涯全体（1867–1916）とロンドン留学期間（1900–1903）の 両方を表現し、短期と長期の継続期間を同じ年表に同居させられます。
          </li>
          <li>
            <code>lane</code> を 3 つに分けることで、職業生活の節目と作品発表の時期を 視覚的に対応付けて読み解けます（例:
            朝日新聞入社後に長編連載が集中する流れ）。
          </li>
          <li>
            <code>unit year</code> + <code>calendar proleptic_gregorian</code> で 和暦・西暦混在の歴史年表を、シンプルな西暦表示に統一できます。
          </li>
        </ul>
        <p>
          <a href="/docs/">文法リファレンス</a> を見れば、 自分の年表を数分で作成できます。
        </p>
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .showcase-page {
    padding: 3rem 1.5rem 5rem;
  }

  .showcase-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .showcase-breadcrumb {
    font-size: 0.875rem;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .showcase-breadcrumb a {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.2em;
  }

  .showcase-header {
    margin-bottom: 2rem;
  }

  .showcase-title {
    font-size: 2rem;
    font-weight: 700;
    font-family: var(--font-display);
    color: var(--color-ink);
    margin: 0 0 0.75rem;
    line-height: 1.25;
  }

  .showcase-description {
    font-size: 1.05rem;
    color: var(--color-muted);
    line-height: var(--line-height-base);
    margin: 0 0 1.25rem;
  }

  .showcase-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin: 0;
    padding: 1rem 1.25rem;
    background: var(--color-panel);
    border-radius: 6px;
    border: 1px solid var(--color-line);
    font-size: 0.875rem;
  }

  .showcase-meta div {
    display: flex;
    gap: 0.4rem;
  }

  .showcase-meta dt {
    color: var(--color-muted);
    font-weight: 500;
  }

  .showcase-meta dt::after {
    content: ":";
  }

  .showcase-meta dd {
    margin: 0;
    color: var(--color-ink);
  }

  .showcase-notes {
    margin-top: 2.5rem;
    padding: 1.5rem;
    background: var(--color-panel);
    border-radius: 8px;
    border: 1px solid var(--color-line);
  }

  .showcase-notes h2 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 1rem;
    color: var(--color-ink);
  }

  .showcase-notes ul {
    margin: 0 0 1rem;
    padding-left: 1.5rem;
    color: var(--color-muted);
    line-height: var(--line-height-base);
  }

  .showcase-notes li {
    margin-bottom: 0.5rem;
  }

  .showcase-notes li:last-child {
    margin-bottom: 0;
  }

  .showcase-notes code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-bg);
    padding: 0.1em 0.3em;
    border-radius: 3px;
    border: 1px solid var(--color-line);
  }

  .showcase-notes p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .showcase-notes a {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.2em;
  }
</style>
