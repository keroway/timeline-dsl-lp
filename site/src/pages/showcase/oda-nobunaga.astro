---
import ShowcasePage from "../../components/ShowcasePage.astro";
import { getT } from "../../i18n/index";

const locale = "ja" as const;
const t = getT(locale);

const source = `timeline "織田信長の生涯 (1534–1582)" {
    title "織田信長の生涯";
    unit year;
    range 1534..1583;
    calendar proleptic_gregorian;
}

lane "生涯" as life { kind custom; order 10; }
lane "合戦" as battle { kind custom; order 20; }
lane "天下布武" as politics { kind custom; order 30; }

span life 1534..1582 "信長の生涯" {};
event life 1534 "誕生（尾張国那古野城）" {};
event life 1551 "家督相続" {};
event life 1582 "本能寺の変（享年 48）" {};

event battle 1560 "桶狭間の戦い（今川義元討取）" {};
event battle 1570 "姉川の戦い" {};
event battle 1573 "槙島城の戦い（足利義昭放逐）" {};
event battle 1575 "長篠の戦い（鉄砲三段撃ち）" {};
event battle 1580 "石山合戦終結" {};

event politics 1559 "尾張国統一" {};
event politics 1568 "上洛・足利義昭を擁立" {};
event politics 1573 "室町幕府滅亡" {};
event politics 1576 "安土城築城開始" {};
event politics 1580 "惣無事令" {};
`;
---

<ShowcasePage
  locale={locale}
  h1="織田信長の生涯"
  title="織田信長の生涯 — Showcase | Timeline DSL"
  description="Timeline DSL で記述した織田信長の生涯年表。合戦・政治の 3 レーン構成で 1534 年から 1582 年を俯瞰する。"
  pathname="/showcase/oda-nobunaga/"
  source={source}
  grid="decade"
  caption="織田信長の生涯年表。Playground でクリックして DSL を編集・カスタマイズできます。"
  breadcrumbs={[
    { name: "Timeline DSL", url: "/" },
    { name: "Showcase", url: "/showcase/" },
    { name: "織田信長の生涯", url: "/showcase/oda-nobunaga/" },
  ]}
  meta={[
    { label: t("showcase.card.period"), value: "1534 〜 1582 年（49 年間）" },
    { label: t("showcase.card.lanes"), value: "生涯 / 合戦 / 天下布武" },
    { label: t("showcase.card.events"), value: "13" },
  ]}
  notesHeading="Timeline DSL の使い所"
>
  <ul>
    <li>
      <code>span</code> で連続する期間（生涯全体）を表現し、
      <code>event</code> で単発の出来事を記録しています。
    </li>
    <li>
      <code>lane</code> を 3 つに分けることで、同じ時期に起きた複数の出来事を 並列して俯瞰できます。
    </li>
    <li>
      <code>unit year</code> + <code>calendar proleptic_gregorian</code> の組み合わせで 歴史年表に最適な西暦表示が得られます。
    </li>
  </ul>
  <p>
    <a href="/docs/">文法リファレンス</a> を見れば、 自分の年表を数分で作成できます。
  </p>
</ShowcasePage>
