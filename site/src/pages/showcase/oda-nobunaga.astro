---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TimelineEmbed from "../../components/TimelineEmbed.astro";
import { breadcrumbLd } from "../../lib/seo-jsonld";

const source = `timeline "織田信長の生涯 (1534–1582)" {
    title "織田信長の生涯";
    unit year;
    range 1534..1583;
    calendar proleptic_gregorian;
}

lane "生涯" as life { kind custom; order 10; }
lane "合戦" as battle { kind custom; order 20; }
lane "天下布武" as politics { kind custom; order 30; }

span life 1534..1582 "信長の生涯" {};
event life 1534 "誕生（尾張国那古野城）" {};
event life 1551 "家督相続" {};
event life 1582 "本能寺の変（享年 48）" {};

event battle 1560 "桶狭間の戦い（今川義元討取）" {};
event battle 1570 "姉川の戦い" {};
event battle 1573 "槙島城の戦い（足利義昭放逐）" {};
event battle 1575 "長篠の戦い（鉄砲三段撃ち）" {};
event battle 1580 "石山合戦終結" {};

event politics 1559 "尾張国統一" {};
event politics 1568 "上洛・足利義昭を擁立" {};
event politics 1573 "室町幕府滅亡" {};
event politics 1576 "安土城築城開始" {};
event politics 1580 "惣無事令" {};
`;

const siteUrl = Astro.site ?? new URL("https://timeline-dsl.pages.dev");
const breadcrumb = breadcrumbLd(
  [
    { name: "Timeline DSL", url: "/" },
    { name: "Showcase", url: "/showcase/" },
    { name: "織田信長の生涯", url: "/showcase/oda-nobunaga/" },
  ],
  siteUrl,
);
---

<BaseLayout
  title="織田信長の生涯 — Showcase | Timeline DSL"
  description="Timeline DSL で記述した織田信長の生涯年表。合戦・政治の 3 レーン構成で 1534 年から 1582 年を俯瞰する。"
  pathname="/showcase/oda-nobunaga/"
  locale="ja"
  extraJsonLd={[breadcrumb]}
>
  <main id="main-content" class="showcase-page">
    <div class="showcase-inner">
      <nav class="showcase-breadcrumb" aria-label="パンくずリスト">
        <a href="/showcase/">Showcase</a>
        <span aria-hidden="true"> / </span>
        <span aria-current="page">織田信長の生涯</span>
      </nav>

      <header class="showcase-header">
        <h1 class="showcase-title">織田信長の生涯</h1>
        <p class="showcase-description">
          戦国時代の覇者・織田信長（1534–1582）の生涯を Timeline DSL で表現した年表です。
          生涯・合戦・天下布武の 3 レーンで、48 年間の軌跡を俯瞰します。
        </p>
        <dl class="showcase-meta">
          <div>
            <dt>期間</dt>
            <dd>1534 〜 1582 年（49 年間）</dd>
          </div>
          <div>
            <dt>レーン</dt>
            <dd>生涯 / 合戦 / 天下布武</dd>
          </div>
          <div>
            <dt>イベント数</dt>
            <dd>13</dd>
          </div>
        </dl>
      </header>

      <TimelineEmbed
        source={source}
        caption="織田信長の生涯年表。Playground でクリックして DSL を編集・カスタマイズできます。"
      />

      <section class="showcase-notes">
        <h2>Timeline DSL の使い所</h2>
        <ul>
          <li>
            <code>span</code> で連続する期間（生涯全体）を表現し、
            <code>event</code> で単発の出来事を記録しています。
          </li>
          <li>
            <code>lane</code> を 3 つに分けることで、同じ時期に起きた複数の出来事を 並列して俯瞰できます。
          </li>
          <li>
            <code>unit year</code> + <code>calendar proleptic_gregorian</code> の組み合わせで 歴史年表に最適な西暦表示が得られます。
          </li>
        </ul>
        <p>
          <a href="/docs/">文法リファレンス</a> を見れば、 自分の年表を数分で作成できます。
        </p>
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .showcase-page {
    padding: 3rem 1.5rem 5rem;
  }

  .showcase-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .showcase-breadcrumb {
    font-size: 0.875rem;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .showcase-breadcrumb a {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.2em;
  }

  .showcase-header {
    margin-bottom: 2rem;
  }

  .showcase-title {
    font-size: 2rem;
    font-weight: 700;
    font-family: var(--font-display);
    color: var(--color-ink);
    margin: 0 0 0.75rem;
    line-height: 1.25;
  }

  .showcase-description {
    font-size: 1.05rem;
    color: var(--color-muted);
    line-height: var(--line-height-base);
    margin: 0 0 1.25rem;
  }

  .showcase-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin: 0;
    padding: 1rem 1.25rem;
    background: var(--color-panel);
    border-radius: 6px;
    border: 1px solid var(--color-line);
    font-size: 0.875rem;
  }

  .showcase-meta div {
    display: flex;
    gap: 0.4rem;
  }

  .showcase-meta dt {
    color: var(--color-muted);
    font-weight: 500;
  }

  .showcase-meta dt::after {
    content: ":";
  }

  .showcase-meta dd {
    margin: 0;
    color: var(--color-ink);
  }

  .showcase-notes {
    margin-top: 2.5rem;
    padding: 1.5rem;
    background: var(--color-panel);
    border-radius: 8px;
    border: 1px solid var(--color-line);
  }

  .showcase-notes h2 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 1rem;
    color: var(--color-ink);
  }

  .showcase-notes ul {
    margin: 0 0 1rem;
    padding-left: 1.5rem;
    color: var(--color-muted);
    line-height: var(--line-height-base);
  }

  .showcase-notes li {
    margin-bottom: 0.5rem;
  }

  .showcase-notes li:last-child {
    margin-bottom: 0;
  }

  .showcase-notes code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-bg);
    padding: 0.1em 0.3em;
    border-radius: 3px;
    border: 1px solid var(--color-line);
  }

  .showcase-notes p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .showcase-notes a {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.2em;
  }
</style>
