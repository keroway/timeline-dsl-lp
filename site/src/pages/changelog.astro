---
import BaseLayout from "../layouts/BaseLayout.astro";
import { createMarkdownProcessor } from "@astrojs/markdown-remark";
import rehypeSanitize from "rehype-sanitize";
import releasesData from "../data/releases.generated.json";

type Release = {
  tagName: string;
  name: string;
  publishedAt: string;
  url: string;
  body: string;
};

const releases = releasesData.releases as Release[];
const latest = releasesData.latest as Release | null;
const pageTitle = "Changelog | Timeline DSL";
const pageDescription = "Timeline DSL の GitHub Releases から生成した changelog です。";
const markdownProcessor = await createMarkdownProcessor({
  gfm: true,
  rehypePlugins: [rehypeSanitize],
  syntaxHighlight: false,
});

const formatDate = (value: string | null | undefined) => {
  if (!value) return null;
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return null;
  return new Intl.DateTimeFormat("ja-JP", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(date);
};

const fetchedAt = formatDate(releasesData.fetchedAt) || "未取得";
const renderedReleases = await Promise.all(
  releases.map(async (release) => ({
    ...release,
    bodyHtml: release.body
      ? (await markdownProcessor.render(release.body)).code
      : "",
  })),
);
---

<BaseLayout title={pageTitle} description={pageDescription} pathname="/changelog/" version={latest?.tagName || releases[0]?.tagName}>

      <main>
        <section class="page-hero">
          <div class="page-hero-inner">
            <p class="eyebrow">GitHub Releases</p>
            <h1>Changelog</h1>
            <p class="lead">
              {releases.length > 0
                ? `${releasesData.repository} のリリース情報を表示しています。`
                : "リリース情報はまだ取得されていません。GitHub Releases の取得後にここへ表示されます。"}
            </p>
            <p class="release-meta">最終取得: {fetchedAt}</p>
          </div>
        </section>

        <section class="section" aria-labelledby="releases-heading">
          <div class="section-header">
            <h2 id="releases-heading">Releases</h2>
          </div>

          {renderedReleases.length > 0 ? (
            <div class="release-list">
              {renderedReleases.map((release) => (
                <article class="release-item">
                  <div class="release-item-header">
                    <div>
                      <p class="release-version">{release.tagName}</p>
                      <h3>{release.name || release.tagName}</h3>
                    </div>
                    <time datetime={release.publishedAt}>
                      {formatDate(release.publishedAt) || "公開日未取得"}
                    </time>
                  </div>
                  {release.body ? (
                    <div class="release-notes" set:html={release.bodyHtml} />
                  ) : (
                    <p class="empty-copy">リリースノート本文はありません。</p>
                  )}
                  {release.url && (
                    <a class="release-link" href={release.url}>
                      GitHubで見る
                    </a>
                  )}
                </article>
              ))}
            </div>
          ) : (
            <div class="empty-state">
              <h3>表示できるリリースはまだありません</h3>
              <p>
                取得スクリプトが成功すると、生成されたリリース一覧がこのページに表示されます。
              </p>
            </div>
          )}
        </section>
      </main>

</BaseLayout>
