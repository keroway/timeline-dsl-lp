---
/**
 * Starlight `components.Footer` override for Docs pages.
 *
 * Starlight 既定の Footer(EditLink / LastUpdated / Pagination)はそのまま残しつつ、
 * その下に LP / Playground / Gallery / Changelog と同じ SiteFooter を追加し、
 * Docs にもサイト共通のフッターナビ + バージョン表示を持たせる(Docs レビュー統一)。
 *
 * 参照元: node_modules/@astrojs/starlight/components/Footer.astro
 */
// virtual:starlight/components/* は Starlight 内部専用の per-component 仮想モジュールで
// 型宣言が公開 exports に含まれない（astro sync でも .d.ts が生成されない）。実行時は
// Vite が解決するため問題なく、DocsSearch.astro の pagefind-ui.js と同じ扱いで型検査のみ抑制する。
// @ts-expect-error virtual:starlight/components/* has no public type declarations
import EditLink from "virtual:starlight/components/EditLink";
// @ts-expect-error virtual:starlight/components/* has no public type declarations
import LastUpdated from "virtual:starlight/components/LastUpdated";
// @ts-expect-error virtual:starlight/components/* has no public type declarations
import Pagination from "virtual:starlight/components/Pagination";
import config from "virtual:starlight/user-config";
import { Icon } from "@astrojs/starlight/components";
import SiteFooter from "./SiteFooter.astro";
import { latest } from "../data/releases";

const currentPath = new URL(Astro.url).pathname;
---

<footer class="sl-flex">
  <div class="meta sl-flex">
    <EditLink />
    <LastUpdated />
  </div>
  <Pagination />

  {
    config.credits && (
      <a class="kudos sl-flex" href="https://starlight.astro.build">
        <Icon name={"starlight"} /> {Astro.locals.t("builtWithStarlight.label")}
      </a>
    )
  }
</footer>

<SiteFooter currentPath={currentPath} version={latest?.tagName} />

<style>
  @layer starlight.core {
    footer {
      flex-direction: column;
      gap: 1.5rem;
    }
    .meta {
      gap: 0.75rem 3rem;
      justify-content: space-between;
      flex-wrap: wrap;
      margin-top: 3rem;
      font-size: var(--sl-text-sm);
      color: var(--sl-color-gray-3);
    }
    .meta > :global(p:only-child) {
      margin-inline-start: auto;
    }

    .kudos {
      align-items: center;
      gap: 0.5em;
      margin: 1.5rem auto;
      font-size: var(--sl-text-xs);
      text-decoration: none;
      color: var(--sl-color-gray-3);
    }
    .kudos:hover {
      color: var(--sl-color-white);
    }
  }

  @layer starlight.components {
    .kudos :global(svg) {
      color: var(--sl-color-orange);
    }
  }
</style>
