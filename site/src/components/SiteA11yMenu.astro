---
import { getT, type Locale } from "../i18n/index";
import A11yMenuPanel from "./A11yMenuPanel.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getT(locale);
const targetLocaleLabel = locale === "ja" ? "EN" : "JP";
---

<button class="lang-toggle" type="button" aria-label={t("nav.lang_toggle.aria_label")}
  >{targetLocaleLabel}</button
>
<A11yMenuPanel menuId="a11y-menu" locale={locale} langToggleSelector=".lang-toggle" />
