---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/changelog.css";
import { createMarkdownProcessor } from "@astrojs/markdown-remark";
import rehypeSanitize from "rehype-sanitize";
import { latest, releases, fetchedAt as rawFetchedAt, repository } from "../data/releases";
import { getT, interpolate, type Locale } from "../i18n/index";
import { changelogLd } from "../lib/seo-jsonld";
import { getSiteUrl, formatDate } from "../lib/site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getT(locale);

const pathname = locale === "ja" ? "/changelog/" : "/en/changelog/";

const siteUrl = getSiteUrl(Astro);
const changelogJsonLd = changelogLd({ siteUrl, pathname, locale, releases });

const markdownProcessor = await createMarkdownProcessor({
  gfm: true,
  rehypePlugins: [rehypeSanitize],
  syntaxHighlight: false,
});

const fetchedAt = formatDate(rawFetchedAt, locale) || t("changelog.fetched_at.unknown");
const renderedReleases = await Promise.all(
  releases.map(async (release) => ({
    ...release,
    bodyHtml: release.body ? (await markdownProcessor.render(release.body)).code : "",
  })),
);
---

<BaseLayout
  title={t("changelog.page.title")}
  description={t("changelog.page.description")}
  pathname={pathname}
  locale={locale}
  ogImagePath="/og/changelog.png"
  version={latest?.tagName || releases[0]?.tagName}
  extraJsonLd={[changelogJsonLd]}
>
  <main id="main-content">
    <section class="page-hero">
      <div class="page-hero-inner">
        <p class="eyebrow">{t("changelog.eyebrow")}</p>
        <h1>Changelog</h1>
        <p class="lead">
          {
            releases.length > 0
              ? interpolate(t("changelog.lead.has_data"), { repository })
              : t("changelog.lead.no_data")
          }
        </p>
        <p class="release-meta">{interpolate(t("changelog.last_fetched"), { date: fetchedAt })}</p>
      </div>
    </section>

    <section class="section" aria-labelledby="releases-heading">
      <div class="section-header">
        <h2 id="releases-heading">Releases</h2>
      </div>

      {
        renderedReleases.length > 0 ? (
          <div class="release-list">
            {renderedReleases.map((release) => (
              <article class="release-item">
                <div class="release-item-header">
                  <div>
                    <p class="release-version">{release.tagName}</p>
                    <h3>{release.name || release.tagName}</h3>
                  </div>
                  <time datetime={release.publishedAt}>
                    {formatDate(release.publishedAt, locale) || t("changelog.release.date_unknown")}
                  </time>
                </div>
                {release.body ? (
                  <div class="release-notes" set:html={release.bodyHtml} />
                ) : (
                  <p class="empty-copy">{t("changelog.release.no_body")}</p>
                )}
                {release.url && (
                  <a class="release-link" href={release.url}>
                    {t("changelog.release.view_on_github")}
                  </a>
                )}
              </article>
            ))}
          </div>
        ) : (
          <div class="empty-state">
            <h3>{t("changelog.empty.heading")}</h3>
            <p>{t("changelog.empty.body")}</p>
          </div>
        )
      }
    </section>
  </main>
</BaseLayout>
