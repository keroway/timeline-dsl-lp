---
/**
 * Starlight `components.Header` override for Docs pages.
 *
 * Starlight 既定のヘッダー構成(SiteTitle / Search / SocialIcons+ThemeSelect+LanguageSelect)
 * のうち、LanguageSelect は SocialIcons override (DocsA11yMenu.astro) が描画する
 * LP 共通の EN/JP 切替ボタン(lang-toggle)と機能が重複するため描画しない。
 * 加えて LP の TOP_NAV(Playground/Gallery/Showcase/Changelog)を追加し、
 * Docs から他セクションへの回遊性を LP と揃える(Docs レビュー統一)。
 * - 現在地の "Docs" 項目と、SocialIcons と重複する "GitHub" 項目は除外する。
 * - デスクトップ幅(md 以上)のみ表示。モバイルは astro.config.mjs の sidebar 先頭
 *   "サイト" グループが同じ回遊導線を担う。
 *
 * 参照元: node_modules/@astrojs/starlight/components/Header.astro
 */
import config from "virtual:starlight/user-config";
// @ts-expect-error virtual:starlight/components/* has no public type declarations
import Search from "virtual:starlight/components/Search";
// @ts-expect-error virtual:starlight/components/* has no public type declarations
import SiteTitle from "virtual:starlight/components/SiteTitle";
// @ts-expect-error virtual:starlight/components/* has no public type declarations
import SocialIcons from "virtual:starlight/components/SocialIcons";
// @ts-expect-error virtual:starlight/components/* has no public type declarations
import ThemeSelect from "virtual:starlight/components/ThemeSelect";
import { getT, resolveLocale } from "../i18n/index";
import { TOP_NAV } from "../data/navigation";

const shouldRenderSearch =
  config.pagefind || config.components.Search !== "@astrojs/starlight/components/Search.astro";

const locale = resolveLocale(Astro);
const t = getT(locale);
const currentPath = new URL(Astro.url).pathname;
const siteNavItems = TOP_NAV.filter(
  (item) => item.labelKey !== "nav.docs" && item.labelKey !== "nav.github",
);
---

<div class="header">
  <div class="title-wrapper sl-flex">
    <SiteTitle />
  </div>
  <nav class="site-nav sl-hidden md:sl-flex print:hidden" aria-label="Primary navigation">
    {
      siteNavItems.map((item) => (
        <a href={item.href(locale)} aria-current={item.isActive(currentPath) ? "page" : undefined}>
          {t(item.labelKey)}
        </a>
      ))
    }
  </nav>
  <div class="sl-flex print:hidden">
    {shouldRenderSearch && <Search />}
  </div>
  <div class="sl-hidden md:sl-flex print:hidden right-group">
    <div class="sl-flex social-icons">
      <SocialIcons />
    </div>
    <ThemeSelect />
  </div>
</div>

<style>
  @layer starlight.core {
    .header {
      display: flex;
      gap: var(--sl-nav-gap);
      justify-content: space-between;
      align-items: center;
      height: 100%;
    }

    .title-wrapper {
      /* Prevent long titles overflowing and covering the search and menu buttons on narrow viewports. */
      overflow: clip;
      /* Avoid clipping focus ring around link inside title wrapper. */
      padding: 0.25rem;
      margin: -0.25rem;
      min-width: 0;
    }

    .site-nav {
      align-items: center;
      gap: 0.15rem;
      flex-shrink: 0;
    }

    .site-nav a {
      display: inline-flex;
      align-items: center;
      padding: 0.4rem 0.6rem;
      border-radius: var(--radius-md, 6px);
      color: var(--sl-color-gray-2);
      font-size: 0.85rem;
      font-weight: 620;
      text-decoration: none;
      white-space: nowrap;
    }

    .site-nav a:hover {
      color: var(--sl-color-white);
      background: var(--sl-color-gray-6);
    }

    .site-nav a[aria-current="page"] {
      color: var(--sl-color-white);
      background: var(--sl-color-gray-6);
    }

    .right-group,
    .social-icons {
      gap: 1rem;
      align-items: center;
    }
    .social-icons::after {
      content: "";
      height: 2rem;
      border-inline-end: 1px solid var(--sl-color-gray-5);
    }

    @media (min-width: 50rem) {
      :global(:root[data-has-sidebar]) {
        --__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
      }
      :global(:root:not([data-has-toc])) {
        --__toc-width: 0rem;
      }
      .header {
        --__sidebar-width: max(0rem, var(--sl-content-inline-start, 0rem) - var(--sl-nav-pad-x));
        --__main-column-fr: calc(
          (
              100% + var(--__sidebar-pad, 0rem) - var(--__toc-width, var(--sl-sidebar-width)) -
                (2 * var(--__toc-width, var(--sl-nav-pad-x))) -
                var(--sl-content-inline-start, 0rem) - var(--sl-content-width)
            ) /
            2
        );
        display: grid;
        grid-template-columns:
          /* 1 (site title): runs up until the main content column’s left edge or the width of the title, whichever is the largest  */
          minmax(
            calc(var(--__sidebar-width) + max(0rem, var(--__main-column-fr) - var(--sl-nav-gap))),
            auto
          )
          /* 2 (site nav): only the space it needs */
          auto
          /* 3 (search box): all free space that is available. */
          1fr
          /* 4 (right items): use the space that these need. */
          auto;
        align-content: center;
      }
    }
  }
</style>
