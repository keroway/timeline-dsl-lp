---
interface Props {
  currentPath?: string;
  version?: string | null;
}

const { currentPath = "", version = null } = Astro.props;
const repositoryUrl = "https://github.com/keroway/timeline-dsl";
const licenseUrl = `${repositoryUrl}/blob/main/LICENSE`;
const versionLabel = version || "Releases";
const versionUrl = version ? `${repositoryUrl}/releases/tag/${version}` : `${repositoryUrl}/releases`;
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-product">
      <a class="footer-brand" href="/">
        <span class="brand-mark footer-brand-mark" aria-hidden="true">td</span>
        <span>Timeline DSL</span>
      </a>
      <span class="footer-copyright">&copy; 2024 keroway</span>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <a href="/docs/" aria-current={currentPath === "/docs/" ? "page" : undefined}>Docs</a>
      <a href="/changelog/" aria-current={currentPath === "/changelog/" ? "page" : undefined}>
        Changelog
      </a>
    </nav>

    <div class="footer-meta" aria-label="Project links">
      <a class="footer-github-link" href={repositoryUrl} rel="noreferrer">
        <svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true" focusable="false">
          <path
            fill="currentColor"
            d="M8 0C3.58 0 0 3.67 0 8.2c0 3.62 2.29 6.7 5.47 7.79.4.08.55-.18.55-.4 0-.2-.01-.86-.01-1.56-2.01.38-2.53-.5-2.69-.96-.09-.24-.48-.96-.82-1.15-.28-.16-.68-.55-.01-.56.63-.01 1.08.59 1.23.84.72 1.24 1.87.89 2.33.68.07-.53.28-.89.51-1.1-1.78-.21-3.64-.91-3.64-4.04 0-.89.31-1.62.82-2.19-.08-.21-.36-1.04.08-2.16 0 0 .67-.22 2.2.84A7.42 7.42 0 0 1 8 3.96c.68 0 1.36.09 2 .28 1.53-1.06 2.2-.84 2.2-.84.44 1.12.16 1.95.08 2.16.51.57.82 1.3.82 2.19 0 3.14-1.87 3.83-3.65 4.04.29.25.54.75.54 1.52 0 1.1-.01 1.98-.01 2.25 0 .22.15.48.55.4A8.13 8.13 0 0 0 16 8.2C16 3.67 12.42 0 8 0Z"
          />
        </svg>
        <span>GitHub</span>
      </a>
      <a href={licenseUrl} rel="noreferrer">License</a>
      <a href={versionUrl} rel="noreferrer">{versionLabel}</a>
    </div>
  </div>
</footer>
