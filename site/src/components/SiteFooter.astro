---
import { getT, resolveLocale, interpolate, localizedPath } from "../i18n/index";

interface Props {
  currentPath?: string;
  version?: string | null;
}

const { currentPath = "", version = null } = Astro.props;
const locale = resolveLocale(Astro);
const t = getT(locale);
const repositoryUrl = "https://github.com/keroway/timeline-dsl";
const licenseUrl = `${repositoryUrl}/blob/main/LICENSE`;
const contributingUrl = `${repositoryUrl}/blob/main/CONTRIBUTING.md`;
const versionLabel = version || "Releases";
const versionUrl = version
  ? `${repositoryUrl}/releases/tag/${version}`
  : `${repositoryUrl}/releases`;

const FOUNDING_YEAR = 2024;
const currentYear = new Date().getFullYear();
const years =
  currentYear > FOUNDING_YEAR ? `${FOUNDING_YEAR}\u2013${currentYear}` : `${FOUNDING_YEAR}`;

const path = (p: string) => localizedPath(p, locale);
const isCurrent = (href: string) => (currentPath === href ? "page" : undefined);

const productLinks = [
  { href: path("/playground/"), label: t("nav.playground") },
  { href: path("/gallery/"), label: t("footer.link.gallery") },
  { href: path("/showcase/"), label: t("footer.link.showcase") },
  { href: path("/changelog/"), label: t("nav.changelog") },
];

const docsLinks = [
  { href: path("/docs/installation/"), label: t("footer.link.installation") },
  { href: path("/docs/quick-start/"), label: t("footer.link.quick_start") },
  { href: path("/docs/grammar/"), label: t("footer.link.grammar") },
  { href: path("/docs/faq/"), label: t("footer.link.faq") },
];
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-product">
      <a class="footer-brand" href={path("/")}>
        <span class="brand-mark footer-brand-mark" aria-hidden="true">
          <img src="/icon.svg" alt="" width="29" height="29" decoding="async" />
        </span>
        <span>Timeline DSL</span>
      </a>
      <span class="footer-copyright">{interpolate(t("footer.copyright"), { years })}</span>
    </div>

    <nav class="footer-nav" aria-label={t("footer.heading.product")}>
      <h2 class="footer-nav-heading">{t("footer.heading.product")}</h2>
      {
        productLinks.map((link) => (
          <a href={link.href} aria-current={isCurrent(link.href)}>
            {link.label}
          </a>
        ))
      }
    </nav>

    <nav class="footer-nav" aria-label={t("footer.heading.docs")}>
      <h2 class="footer-nav-heading">{t("footer.heading.docs")}</h2>
      {
        docsLinks.map((link) => (
          <a href={link.href} aria-current={isCurrent(link.href)}>
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="footer-meta" aria-label={t("footer.heading.project")}>
      <h2 class="footer-nav-heading">{t("footer.heading.project")}</h2>
      <a class="footer-github-link" href={repositoryUrl} rel="noreferrer">
        <svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true" focusable="false">
          <path
            fill="currentColor"
            d="M8 0C3.58 0 0 3.67 0 8.2c0 3.62 2.29 6.7 5.47 7.79.4.08.55-.18.55-.4 0-.2-.01-.86-.01-1.56-2.01.38-2.53-.5-2.69-.96-.09-.24-.48-.96-.82-1.15-.28-.16-.68-.55-.01-.56.63-.01 1.08.59 1.23.84.72 1.24 1.87.89 2.33.68.07-.53.28-.89.51-1.1-1.78-.21-3.64-.91-3.64-4.04 0-.89.31-1.62.82-2.19-.08-.21-.36-1.04.08-2.16 0 0 .67-.22 2.2.84A7.42 7.42 0 0 1 8 3.96c.68 0 1.36.09 2 .28 1.53-1.06 2.2-.84 2.2-.84.44 1.12.16 1.95.08 2.16.51.57.82 1.3.82 2.19 0 3.14-1.87 3.83-3.65 4.04.29.25.54.75.54 1.52 0 1.1-.01 1.98-.01 2.25 0 .22.15.48.55.4A8.13 8.13 0 0 0 16 8.2C16 3.67 12.42 0 8 0Z"
          ></path>
        </svg>
        <span>GitHub</span>
      </a>
      <a href={licenseUrl} rel="noreferrer">{t("footer.link.license")}</a>
      <a href={versionUrl} rel="noreferrer">{versionLabel}</a>
      <a href={contributingUrl} rel="noreferrer">{t("footer.link.contributing")}</a>
    </div>
  </div>
</footer>

<style>
  /* LP(global.css 経由)と同一の見た目を Docs(Starlight)でも再現するため、
     このコンポーネント自身の scoped style として自己完結化する(#483)。
     global.css は BaseLayout(LP)専用で Docs では読み込まれないため。 */
  .site-footer {
    border-top: 1px solid var(--color-line);
    background:
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--color-accent), transparent 93%),
        color-mix(in srgb, var(--color-gold), transparent 96%)
      ),
      var(--color-panel);
    color: var(--color-muted);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: minmax(13rem, 1.1fr) repeat(3, minmax(9rem, 0.8fr));
    align-items: start;
    gap: 1.5rem var(--space-xl);
    width: var(--layout-width);
    margin: 0 auto;
    padding: 2rem 0;
    font-size: var(--text-sm);
  }

  .footer-product {
    display: grid;
    gap: 0.45rem;
  }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    width: fit-content;
    color: var(--color-ink);
    font-weight: 720;
    text-decoration: none;
  }

  .footer-brand:hover {
    color: var(--color-accent-strong);
  }

  /* SiteHeader の .brand-mark(global.css)は Docs で読み込まれないため、
     footer 用バッジの見た目をこのセレクタ単体で完結させる(値は global.css の
     .brand-mark と同一、サイズのみ footer 用に 1.8rem で上書き) */
  .footer-brand-mark {
    display: inline-grid;
    place-items: center;
    width: 1.8rem;
    height: 1.8rem;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-brand-badge-bg);
    box-shadow: 0 8px 20px color-mix(in srgb, var(--color-ink), transparent 86%);
  }

  .footer-brand-mark img {
    display: block;
    width: 100%;
    height: 100%;
  }

  .footer-copyright {
    font-size: var(--text-xs);
  }

  .footer-nav-heading {
    margin: 0 0 0.2rem;
    color: var(--color-ink);
    font-size: var(--text-2xs);
    font-weight: 720;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .footer-nav,
  .footer-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-2xs);
  }

  .footer-nav a,
  .footer-meta a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 2.25rem;
    padding: 0.42rem 0.62rem;
    border-radius: var(--radius-md);
    color: var(--color-muted);
    font-weight: 650;
    text-decoration: none;
  }

  .footer-nav a:hover,
  .footer-meta a:hover,
  .footer-nav a[aria-current="page"] {
    background: var(--color-bg);
    color: var(--color-ink);
  }

  .footer-github-link svg {
    flex: 0 0 auto;
  }

  @media (max-width: 820px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
