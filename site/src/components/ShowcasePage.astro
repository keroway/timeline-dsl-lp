---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimelineEmbed from "./TimelineEmbed.astro";
import { breadcrumbLd } from "../lib/seo-jsonld";
import { getSiteUrl } from "../lib/site";
import type { Locale } from "../i18n/index";

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface MetaItem {
  label: string;
  value: string;
}

interface Props {
  locale: Locale;
  h1: string;
  title: string;
  description: string;
  pathname: string;
  source: string;
  caption: string;
  breadcrumbs: BreadcrumbItem[];
  meta: MetaItem[];
  notesHeading: string;
}

const {
  locale,
  h1,
  title,
  description,
  pathname,
  source,
  caption,
  breadcrumbs,
  meta,
  notesHeading,
} = Astro.props;

const siteUrl = getSiteUrl(Astro);
const breadcrumb = breadcrumbLd(breadcrumbs, siteUrl);
---

<BaseLayout
  title={title}
  description={description}
  pathname={pathname}
  locale={locale}
  extraJsonLd={[breadcrumb]}
>
  <main id="main-content" class="showcase-page">
    <div class="showcase-inner">
      <nav
        class="showcase-breadcrumb"
        aria-label={locale === "ja" ? "パンくずリスト" : "Breadcrumb"}
      >
        {
          breadcrumbs.slice(1, -1).map((item) => (
            <>
              <a href={item.url}>{item.name}</a>
              <span aria-hidden="true"> / </span>
            </>
          ))
        }
        <span aria-current="page">{breadcrumbs.at(-1)?.name}</span>
      </nav>

      <header class="showcase-header">
        <h1 class="showcase-title">{h1}</h1>
        <p class="showcase-description">{description}</p>
        <dl class="showcase-meta">
          {
            meta.map((item) => (
              <div>
                <dt>{item.label}</dt>
                <dd>{item.value}</dd>
              </div>
            ))
          }
        </dl>
      </header>

      <TimelineEmbed source={source} caption={caption} />

      <section class="showcase-notes">
        <h2>{notesHeading}</h2>
        <slot />
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .showcase-page {
    padding: 3rem 1.5rem 5rem;
  }

  .showcase-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .showcase-breadcrumb {
    font-size: 0.875rem;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .showcase-breadcrumb a {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.2em;
  }

  .showcase-header {
    margin-bottom: 2rem;
  }

  .showcase-title {
    font-size: 2rem;
    font-weight: 700;
    font-family: var(--font-display);
    color: var(--color-ink);
    margin: 0 0 0.75rem;
    line-height: 1.25;
  }

  .showcase-description {
    font-size: 1.05rem;
    color: var(--color-muted);
    line-height: var(--line-height-base);
    margin: 0 0 1.25rem;
  }

  .showcase-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin: 0;
    padding: 1rem 1.25rem;
    background: var(--color-panel);
    border-radius: 6px;
    border: 1px solid var(--color-line);
    font-size: 0.875rem;
  }

  .showcase-meta div {
    display: flex;
    gap: 0.4rem;
  }

  .showcase-meta dt {
    color: var(--color-muted);
    font-weight: 500;
  }

  .showcase-meta dt::after {
    content: ":";
  }

  .showcase-meta dd {
    margin: 0;
    color: var(--color-ink);
  }

  .showcase-notes {
    margin-top: 2.5rem;
    padding: 1.5rem;
    background: var(--color-panel);
    border-radius: 8px;
    border: 1px solid var(--color-line);
  }

  .showcase-notes h2 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 1rem;
    color: var(--color-ink);
  }

  .showcase-notes :global(ul) {
    margin: 0 0 1rem;
    padding-left: 1.5rem;
    color: var(--color-muted);
    line-height: var(--line-height-base);
  }

  .showcase-notes :global(li) {
    margin-bottom: 0.5rem;
  }

  .showcase-notes :global(li:last-child) {
    margin-bottom: 0;
  }

  .showcase-notes :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-bg);
    padding: 0.1em 0.3em;
    border-radius: 3px;
    border: 1px solid var(--color-line);
  }

  .showcase-notes :global(p) {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .showcase-notes :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.2em;
  }
</style>
