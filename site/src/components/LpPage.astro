---
import BaseLayout from "../layouts/BaseLayout.astro";
import releasesData from "../data/releases.generated.json";
import { getT, type Locale } from "../i18n/index";
import { softwareApplicationLd } from "../lib/seo-jsonld";
import "../styles/lp.css";
import HeroSection from "./lp/HeroSection.astro";
import FeaturesSection from "./lp/FeaturesSection.astro";
import WorkflowSection from "./lp/WorkflowSection.astro";
import UsecasesSection from "./lp/UsecasesSection.astro";
import InstallSection from "./lp/InstallSection.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getT(locale);

type Release = {
  tagName: string;
  name: string;
  publishedAt: string;
  url: string;
  body: string;
};

const latest = releasesData.latest as Release | null;
const pageTitle = t("lp.page.title");
const pageDescription = t("lp.page.description");
const pathname = locale === "ja" ? "/" : "/en/";

const siteUrl = Astro.site ?? new URL("https://timeline-dsl.pages.dev");
const homeJsonLd = [softwareApplicationLd(siteUrl, locale)];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  pathname={pathname}
  locale={locale}
  version={latest?.tagName}
  extraJsonLd={homeJsonLd}
>
  <main id="main-content">
    <HeroSection locale={locale} />
    <FeaturesSection locale={locale} />
    <WorkflowSection locale={locale} />
    <UsecasesSection locale={locale} />
    <InstallSection locale={locale} />
  </main>

  <Fragment slot="body-end">
    <script>
      import { initCopyButtons, initMotion } from "../lib/lp-motion";
      initCopyButtons();
      initMotion();
    </script>
  </Fragment>
</BaseLayout>
