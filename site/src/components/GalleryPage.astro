---
import BaseLayout from "../layouts/BaseLayout.astro";
import { latest } from "../data/releases";
import gallerySamples from "../data/gallery-samples.json";
import { getT, type Locale } from "../i18n/index";
import { itemListLd } from "../lib/seo-jsonld";
import { getSiteUrl } from "../lib/site";
import GalleryGrid from "./gallery/GalleryGrid.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getT(locale);

const pathname = locale === "ja" ? "/gallery/" : "/en/gallery/";

const rawSamples = gallerySamples as {
  id: string;
  title: { ja: string; en: string };
  description: { ja: string; en: string };
  tags: string[];
  source: string;
}[];

// title/description のみロケールで解決する。source(DSL)はスコープ外のため日本語のまま共通。
const samples = rawSamples.map((sample) => ({
  ...sample,
  title: sample.title[locale],
  description: sample.description[locale],
}));

const msgs = {
  errorSummary: t("gallery.error.summary"),
  retry: t("gallery.error.retry"),
  resultCount: t("gallery.filter.result_count"),
  previewZoomBtnAriaLabel: t("gallery.preview.zoom_btn_aria_label"),
  previewModalAriaLabel: t("gallery.preview_modal.aria_label"),
};

const siteUrl = getSiteUrl(Astro);
const sampleList = itemListLd({
  siteUrl,
  pathname,
  locale,
  name: t("gallery.page.title"),
  description: t("gallery.page.description"),
  items: samples.map((sample) => ({ name: sample.title, description: sample.description })),
});
---

<BaseLayout
  title={t("gallery.page.title")}
  description={t("gallery.page.description")}
  pathname={pathname}
  locale={locale}
  ogImagePath="/og/gallery.png"
  version={latest?.tagName}
  extraJsonLd={[sampleList]}
>
  <main id="main-content">
    <section class="page-hero">
      <div class="page-hero-inner">
        <p class="eyebrow">{t("gallery.eyebrow")}</p>
        <h1>Gallery</h1>
        <p class="lead">{t("gallery.lead")}</p>
        <p class="gallery-showcase-link">
          <a href={locale === "ja" ? "/showcase/" : "/en/showcase/"}>{t("gallery.see_showcase")}</a>
        </p>
      </div>
    </section>

    <GalleryGrid samples={samples} locale={locale} />
  </main>

  <script
    is:inline
    slot="body-end"
    id="gallery-samples-data"
    type="application/json"
    set:html={JSON.stringify(samples.map((s) => ({ id: s.id, source: s.source, title: s.title })))}
  />
  <script
    is:inline
    slot="body-end"
    id="gallery-i18n"
    type="application/json"
    set:html={JSON.stringify(msgs)}
  />
</BaseLayout>

<script>
  import { renderTdslSvgWithOptions } from "../lib/tdsl-wasm";
  import { interpolate } from "../i18n/index";

  type SampleData = { id: string; source: string; title: string };
  type GalleryMsgs = {
    errorSummary: string;
    retry: string;
    resultCount: string;
    previewZoomBtnAriaLabel: string;
    previewModalAriaLabel: string;
  };

  const dataEl = document.getElementById("gallery-samples-data");
  const samplesData = JSON.parse(dataEl?.textContent || "[]") as SampleData[];
  const i18nEl = document.getElementById("gallery-i18n");
  const msgs = JSON.parse(i18nEl?.textContent || "{}") as GalleryMsgs;

  const showEventLabelsToggle = document.querySelector<HTMLInputElement>(
    "[data-gallery-show-event-labels-toggle]",
  );
  const GALLERY_SHOW_EVENT_LABELS_KEY = "tdsl-gallery-show-event-labels";
  try {
    if (showEventLabelsToggle) {
      showEventLabelsToggle.checked =
        window.localStorage.getItem(GALLERY_SHOW_EVENT_LABELS_KEY) === "true";
    }
  } catch {
    // localStorage 無効環境ではデフォルト（オフ）のまま継続する。
  }

  const renderSample = async (sample: SampleData) => {
    const el = document.querySelector<HTMLElement>(`[data-gallery-preview="${sample.id}"]`);
    if (!el) return;
    try {
      // SVG は自社 WASM ライブラリが生成する信頼済みコンテンツ（playground.astro と同パターン）
      const svg = await renderTdslSvgWithOptions(sample.source, undefined, {
        showEventLabels: showEventLabelsToggle?.checked ?? false,
      });
      el.innerHTML = svg;
      el.classList.add("has-svg");
      const zoomBtn = document.querySelector<HTMLButtonElement>(
        `[data-gallery-zoom-trigger="${sample.id}"]`,
      );
      if (zoomBtn) zoomBtn.hidden = false;
    } catch (error) {
      const message = error instanceof Error ? error.message : String(error);
      const errorDiv = document.createElement("div");
      errorDiv.className = "gallery-preview-error";
      const detailsEl = document.createElement("details");
      detailsEl.className = "gallery-error-detail";
      const summaryEl = document.createElement("summary");
      summaryEl.textContent = msgs.errorSummary;
      const preEl = document.createElement("pre");
      preEl.className = "gallery-error-message";
      preEl.textContent = message;
      const retryBtn = document.createElement("button");
      retryBtn.type = "button";
      retryBtn.className = "gallery-retry-btn";
      retryBtn.textContent = msgs.retry;
      retryBtn.addEventListener("click", () => {
        el.replaceChildren();
        const placeholder = document.createElement("div");
        placeholder.className = "gallery-preview-placeholder";
        placeholder.setAttribute("aria-hidden", "true");
        for (let i = 0; i < 3; i++) {
          const dot = document.createElement("span");
          dot.className = "gallery-loading-dot";
          placeholder.append(dot);
        }
        el.append(placeholder);
        renderSample(sample);
      });
      detailsEl.append(summaryEl, preEl);
      errorDiv.append(detailsEl, retryBtn);
      el.replaceChildren(errorDiv);
    }
  };

  // ビューポート内（および近傍）に入ったサンプルだけ遅延描画する。第一スクリーン外の
  // 即時描画と 479KB WASM の即時ロードを避け、LCP / INP を改善する。WASM は
  // renderTdslSvg → loadTdslWasm() の singleton キャッシュで初回描画時に 1 度だけロードされる。
  if ("IntersectionObserver" in window) {
    const samplesById = new Map(samplesData.map((s) => [s.id, s]));
    const observer = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          obs.unobserve(entry.target);
          const id = entry.target.getAttribute("data-gallery-preview");
          const sample = id ? samplesById.get(id) : undefined;
          if (sample) renderSample(sample);
        }
      },
      { rootMargin: "200px 0px" },
    );
    for (const sample of samplesData) {
      const el = document.querySelector(`[data-gallery-preview="${sample.id}"]`);
      if (el) observer.observe(el);
    }
  } else {
    // IntersectionObserver 非対応環境では従来どおり全サンプルを順次描画する。
    for (const sample of samplesData) {
      await renderSample(sample);
    }
  }

  // ラベル常時表示トグル: 切り替え時に描画済みのカードだけ再描画する（未描画カードは IntersectionObserver が抜けた際に現在のトグル状態で描画される）。
  showEventLabelsToggle?.addEventListener("change", () => {
    try {
      window.localStorage.setItem(
        GALLERY_SHOW_EVENT_LABELS_KEY,
        String(showEventLabelsToggle.checked),
      );
    } catch {
      // 保存に失敗しても再描画自体は継続する。
    }
    for (const sample of samplesData) {
      const el = document.querySelector(`[data-gallery-preview="${sample.id}"]`);
      if (el?.classList.contains("has-svg")) renderSample(sample);
    }
  });

  // タグ filter: 初期 hidden の filter bar を有効化し、選択タグ（OR）でカードを絞り込む。
  // hidden 属性での show/hide なので、未描画カードを再表示すると IntersectionObserver の
  // 監視が継続しており交差時に描画される（初期 HTML は全カード可視 = no-JS フォールバック）。
  const filterBar = document.querySelector<HTMLElement>(".gallery-filter");
  if (filterBar) {
    const allBtn = filterBar.querySelector<HTMLButtonElement>("[data-filter-all]");
    const tagBtns = Array.from(filterBar.querySelectorAll<HTMLButtonElement>("[data-filter-tag]"));
    const cards = Array.from(document.querySelectorAll<HTMLElement>(".gallery-card"));
    const statusEl = document.querySelector<HTMLElement>("[data-filter-status]");
    const selected = new Set<string>();

    const apply = () => {
      let visible = 0;
      for (const card of cards) {
        const tags = (card.getAttribute("data-tags") || "").split(" ").filter(Boolean);
        const show = selected.size === 0 || tags.some((tag) => selected.has(tag));
        card.hidden = !show;
        if (show) visible++;
      }
      const filtering = selected.size > 0;
      allBtn?.setAttribute("aria-pressed", String(!filtering));
      if (statusEl) {
        statusEl.hidden = !filtering;
        statusEl.textContent = filtering
          ? interpolate(msgs.resultCount, { count: String(visible) })
          : "";
      }
    };

    for (const btn of tagBtns) {
      btn.addEventListener("click", () => {
        const tag = btn.getAttribute("data-filter-tag");
        if (!tag) return;
        const next = !selected.has(tag);
        if (next) selected.add(tag);
        else selected.delete(tag);
        btn.setAttribute("aria-pressed", String(next));
        apply();
      });
    }

    allBtn?.addEventListener("click", () => {
      if (selected.size === 0) return;
      selected.clear();
      for (const btn of tagBtns) btn.setAttribute("aria-pressed", "false");
      apply();
    });

    filterBar.hidden = false;
    apply();
  }

  // 拡大表示モーダル(#481)。native <dialog>.showModal() でフォーカストラップ・
  // Esc クローズ・トップレイヤー表示を得る（SiteHeader のモバイルナビ disclosure と同パターン）。
  const zoomDialog = document.getElementById("gallery-preview-dialog") as HTMLDialogElement | null;
  const zoomDialogTitle = document.getElementById("gallery-preview-dialog-title");
  const zoomDialogContent = document.getElementById("gallery-preview-dialog-content");
  const zoomDialogClose = document.getElementById(
    "gallery-preview-dialog-close",
  ) as HTMLButtonElement | null;
  const samplesById = new Map(samplesData.map((s) => [s.id, s]));
  let lastZoomTrigger: HTMLButtonElement | null = null;

  function openZoomDialog(id: string, trigger: HTMLButtonElement): void {
    if (!zoomDialog || !zoomDialogContent || !zoomDialogTitle) return;
    const sourceEl = document.querySelector<HTMLElement>(`[data-gallery-preview="${id}"] svg`);
    if (!sourceEl) return;
    const sample = samplesById.get(id);
    zoomDialogContent.replaceChildren(sourceEl.cloneNode(true));
    zoomDialogTitle.textContent = sample?.title ?? "";
    zoomDialog.setAttribute(
      "aria-label",
      interpolate(msgs.previewModalAriaLabel, { title: sample?.title ?? "" }),
    );
    lastZoomTrigger = trigger;
    zoomDialog.showModal();
  }

  function closeZoomDialog(): void {
    zoomDialog?.close();
  }

  for (const trigger of document.querySelectorAll<HTMLButtonElement>(
    "[data-gallery-zoom-trigger]",
  )) {
    const id = trigger.getAttribute("data-gallery-zoom-trigger");
    if (!id) continue;
    trigger.addEventListener("click", () => openZoomDialog(id, trigger));
  }

  zoomDialog?.addEventListener("close", () => {
    zoomDialogContent?.replaceChildren();
    lastZoomTrigger?.focus();
  });

  zoomDialog?.addEventListener("click", (e: MouseEvent) => {
    if (e.target === zoomDialog) closeZoomDialog();
  });

  zoomDialogClose?.addEventListener("click", closeZoomDialog);
</script>

<style>
  .gallery-showcase-link {
    margin: 0.75rem 0 0;
    font-size: var(--text-sm);
  }

  .gallery-showcase-link a {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
  }

  .gallery-showcase-link a:hover {
    text-decoration: underline;
  }

  /* JS で動的生成される要素のため :global() で適用する。TimelineEmbed.astro と配色を揃える */
  :global(.gallery-preview-error) {
    padding: 0.75rem 1rem;
    color: var(--color-warm);
    background: color-mix(in srgb, var(--color-warm), transparent 92%);
    font-size: var(--text-xs);
    border-radius: 4px;
    text-align: center;
  }

  /* エラー詳細の 0.75rem / 0.7rem はスケール段から ±0.02 超の縮小表示用装飾値のため据置(#509) */
  :global(.gallery-error-detail) {
    font-size: 0.75rem;
    color: var(--color-muted);
    text-align: left;
    cursor: pointer;
  }

  :global(.gallery-error-message) {
    margin: 0.25rem 0 0;
    padding: 0.3rem;
    font-size: 0.7rem;
    white-space: pre-wrap;
    word-break: break-all;
    max-height: 80px;
    overflow: auto;
  }

  :global(.gallery-retry-btn) {
    margin-top: 0.5rem;
    padding: 0.3em 0.8em;
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-accent);
    font-size: var(--text-2xs);
    cursor: pointer;
  }

  :global(.gallery-retry-btn):hover {
    background: var(--color-accent);
    color: var(--color-on-accent);
  }

  :global(.gallery-retry-btn):focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>
