---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/playground.css";
import PlaygroundEditor from "./playground/PlaygroundEditor.astro";
import PlaygroundPreview from "./playground/PlaygroundPreview.astro";
import PlaygroundDiagnostics from "./playground/PlaygroundDiagnostics.astro";
import { getT, type Locale } from "../i18n/index";
import { itemListLd } from "../lib/seo-jsonld";
import { getSiteUrl } from "../lib/site";
import { getPlaygroundSamples } from "../data/playground-samples";
import { buildPlaygroundMsgs } from "../lib/playground-messages";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getT(locale);

const pathname = locale === "ja" ? "/playground/" : "/en/playground/";

const samples = getPlaygroundSamples(locale);

const msgs = buildPlaygroundMsgs(t);

const siteUrl = getSiteUrl(Astro);
const sampleList = itemListLd({
  siteUrl,
  pathname,
  locale,
  name: t("playground.page.title"),
  description: t("playground.page.description"),
  items: samples.map((sample) => ({ name: sample.label })),
});
---

<BaseLayout
  title={t("playground.page.title")}
  description={t("playground.page.description")}
  pathname={pathname}
  locale={locale}
  ogImagePath="/og/playground.png"
  shellClass="playground-shell"
  extraJsonLd={[sampleList]}
>
  <main
    id="main-content"
    class="playground-main"
    data-playground-root
    data-playground-state="loading"
  >
    <section class="playground-head" aria-labelledby="playground-heading">
      <div>
        <p class="eyebrow">{t("playground.eyebrow")}</p>
        <h1 id="playground-heading">Playground</h1>
        <p class="playground-lead">
          {t("playground.lead")}
        </p>
      </div>
      <div class="playground-status" aria-live="polite" aria-atomic="true" data-status>
        {t("playground.status.init")}
      </div>
    </section>

    <section class="playground-toolbar" aria-label={t("playground.toolbar.aria_label")}>
      <label class="sample-picker">
        <span>{t("playground.toolbar.sample_label")}</span>
        <select data-sample-select>
          {samples.map((sample) => <option value={sample.id}>{sample.label}</option>)}
        </select>
      </label>
      <label class="scale-picker">
        <span>{t("playground.toolbar.scale_label")}</span>
        <select data-scale-select>
          <option value="0">{t("playground.scale.auto")}</option>
          <option value="0.5">0.5×</option>
          <option value="1">1×</option>
          <option value="2">2×</option>
          <option value="4">4×</option>
          <option value="8">8×</option>
        </select>
      </label>
      <label class="labels-toggle">
        <input type="checkbox" data-show-event-labels-toggle />
        <span>{t("playground.toolbar.show_event_labels")}</span>
      </label>
      <div class="playground-actions">
        <input
          type="file"
          accept=".tdsl,.txt"
          aria-hidden="true"
          tabindex="-1"
          data-open-file-input
          style="display:none"
        />
        <button class="button button-secondary" type="button" data-open-file>
          {t("playground.toolbar.open_file")}
        </button>
        <button
          class="button button-secondary"
          type="button"
          data-copy-link
          aria-label={t("playground.toolbar.copy_link_aria")}
        >
          {t("playground.toolbar.copy_link")}
        </button>
        <button class="button button-secondary" type="button" data-download-tdsl>
          {t("playground.toolbar.save_tdsl")}
        </button>
        <button class="button button-secondary" type="button" data-download-svg disabled>
          {t("playground.toolbar.save_svg")}
        </button>
        <button class="button button-primary" type="button" data-download-html disabled>
          {t("playground.toolbar.save_html")}
        </button>
      </div>
      <div
        class="playground-share-live"
        role="status"
        aria-live="polite"
        aria-atomic="true"
        data-share-live
      >
      </div>
    </section>

    <section class="playground-workspace" aria-label={t("playground.workspace.aria_label")}>
      <PlaygroundEditor />
      <PlaygroundPreview locale={locale} />
      <PlaygroundDiagnostics locale={locale} />
    </section>
  </main>

  <Fragment slot="body-end">
    <div class="tdsl-tooltip" id="tdsl-tooltip" role="tooltip" aria-hidden="true"></div>
    <script
      is:inline
      type="application/json"
      id="playground-samples"
      set:html={JSON.stringify(samples)}
    />
    <script
      is:inline
      type="application/json"
      id="playground-i18n"
      set:html={JSON.stringify(msgs)}
    />
    <script>
      import { initPlayground } from "../lib/playground-controller";

      initPlayground();
    </script>
  </Fragment>
</BaseLayout>
