---
import { getSiteUrl } from "../lib/site";

type Props = {
  title: string;
  description: string;
  pathname: string;
  imagePath?: string;
  locale?: string;
};

const { title, description, pathname, imagePath = "/og/default.png", locale = "ja" } = Astro.props;

const siteUrl = getSiteUrl(Astro);
const pageUrl = new URL(pathname, siteUrl).toString();
const imageUrl = new URL(imagePath, siteUrl).toString();

// og:image:type は画像実体の拡張子から導出し、メタと実体の乖離を防ぐ（DESIGN.md §9 参照）。
const IMAGE_MIME_BY_EXT: Record<string, string> = {
  png: "image/png",
  jpg: "image/jpeg",
  jpeg: "image/jpeg",
  webp: "image/webp",
  gif: "image/gif",
  svg: "image/svg+xml",
};
const imageExt = imagePath.split("?")[0].split("#")[0].split(".").pop()?.toLowerCase();
const imageType = imageExt ? IMAGE_MIME_BY_EXT[imageExt] : undefined;
---

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" href="/icon.svg" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:alt" content={title} />
{imageType && <meta property="og:image:type" content={imageType} />}
{/* OG 画像は 1200x630 固定（DESIGN.md §9）。実体もこの寸法で制作する。 */}
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:url" content={pageUrl} />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Timeline DSL" />
<meta property="og:locale" content={locale === "en" ? "en_US" : "ja_JP"} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
<meta name="twitter:image:alt" content={title} />
