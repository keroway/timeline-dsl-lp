---
type Props = {
  title: string;
  description: string;
  pathname: string;
  imagePath?: string;
};

const {
  title,
  description,
  pathname,
  imagePath = "/og/timeline-dsl.svg",
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://timeline-dsl.pages.dev");
const pageUrl = new URL(pathname, siteUrl).toString();
const imageUrl = new URL(imagePath, siteUrl).toString();
---

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:alt" content={title} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:url" content={pageUrl} />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Timeline DSL" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
<meta name="twitter:image:alt" content={title} />
