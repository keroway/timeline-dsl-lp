---
import { getT, type Locale } from "../i18n/index";

interface Props {
  currentPath?: string;
}

const { currentPath = "" } = Astro.props;
const locale = (Astro.currentLocale ?? "ja") as Locale;
const t = getT(locale);
const targetLocaleLabel = locale === "ja" ? "EN" : "JP";
---

<header class="site-header">
  <nav class="nav" aria-label="Primary navigation">
    <a class="brand" href="/">
      <span class="brand-mark" aria-hidden="true">
        <img src="/icon.svg" alt="" width="32" height="32" decoding="async" />
      </span>
      <span>Timeline DSL</span>
    </a>
    <div class="nav-links">
      <a href="/playground/" aria-current={currentPath === "/playground/" ? "page" : undefined}
        >Playground</a
      >
      <a href="/gallery/" aria-current={currentPath === "/gallery/" ? "page" : undefined}>Gallery</a
      >
      {
        locale === "ja" && (
          <a href="/showcase/" aria-current={currentPath === "/showcase/" ? "page" : undefined}>
            Showcase
          </a>
        )
      }
      <a href="/docs/">Docs</a>
      <a href="/changelog/" aria-current={currentPath === "/changelog/" ? "page" : undefined}
        >Changelog</a
      >
      <a href="https://github.com/keroway/timeline-dsl">GitHub</a>
      <button
        class="search-toggle"
        type="button"
        aria-label={t("nav.search.aria_label")}
        id="site-search-btn"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
      </button>
      <button
        class="lang-toggle"
        type="button"
        aria-label={t("nav.lang_toggle.aria_label")}
        data-unavailable-msg={t("nav.lang_toggle.unavailable")}>{targetLocaleLabel}</button
      >
      <button
        class="a11y-toggle"
        type="button"
        aria-haspopup="menu"
        aria-expanded="false"
        aria-controls="a11y-menu"
        aria-label={t("a11y.menu.toggle_aria_label")}
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="16"></line>
          <line x1="8" y1="12" x2="16" y2="12"></line>
        </svg>
      </button>
    </div>
  </nav>

  <div id="a11y-menu" class="a11y-menu" hidden>
    <div class="a11y-menu-inner">
      <div class="a11y-section">
        <h3>{t("a11y.section.visual")}</h3>
        <div class="a11y-field">
          <label>
            <input type="checkbox" data-a11y-reduced-motion />
            {t("a11y.field.reduced_motion")}
          </label>
        </div>
        <div class="a11y-field">
          <label>
            <input type="checkbox" data-a11y-high-contrast />
            {t("a11y.field.high_contrast")}
          </label>
        </div>
      </div>
      <div class="a11y-section">
        <h3>{t("a11y.section.readability")}</h3>
        <div class="a11y-field">
          <label>
            <input type="checkbox" data-a11y-text-spacing-input />
            {t("a11y.field.text_spacing")}
          </label>
        </div>
        <div class="a11y-field">
          <select data-a11y-text-size>
            <option value="normal">{t("a11y.text_size.normal")}</option>
            <option value="large">{t("a11y.text_size.large")}</option>
            <option value="extra-large">{t("a11y.text_size.extra_large")}</option>
            <option value="xx-large">{t("a11y.text_size.xx_large")}</option>
          </select>
        </div>
      </div>
      <div class="sr-only" aria-live="polite" data-a11y-live></div>
    </div>
  </div>
</header>

<dialog class="site-search-dialog" id="site-search-dialog" aria-label={t("nav.search.aria_label")}>
  <div class="site-search-inner" id="site-search-ui" data-not-built-msg={t("nav.search.not_built")}>
  </div>
</dialog>

<style>
  .a11y-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    border: 1px solid var(--color-line);
    border-radius: 6px;
    background: var(--color-bg);
    color: var(--color-muted);
    cursor: pointer;
    transition: all 0.2s;
  }

  .a11y-toggle:hover {
    color: var(--color-ink);
    background: var(--color-panel);
    border-color: var(--color-ink);
  }

  .a11y-toggle[aria-expanded="true"] {
    background: var(--color-panel);
    color: var(--color-accent-strong);
    border-color: var(--color-accent);
  }

  .a11y-menu {
    position: absolute;
    top: 100%;
    right: 0;
    width: min(320px, 100vw);
    max-height: calc(100vh - 5rem);
    overflow-y: auto;
    background: var(--color-bg);
    border: 1px solid var(--color-line);
    border-top: none;
    box-shadow: 0 10px 30px color-mix(in srgb, var(--color-ink), transparent 90%);
    z-index: 100;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .a11y-menu:not([hidden]) {
    display: block;
  }

  .a11y-menu-inner {
    padding: 1.25rem;
  }

  .a11y-section + .a11y-section {
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-line);
  }

  .a11y-section h3 {
    margin: 0 0 0.75rem;
    font-size: 0.85rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .a11y-field {
    margin: 0.5rem 0;
  }

  .a11y-field label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    cursor: pointer;
  }

  .a11y-field select {
    width: 100%;
    height: 2.25rem;
    padding: 0 0.5rem;
    border: 1px solid var(--color-line);
    border-radius: 4px;
    background: var(--color-bg);
    color: var(--color-ink);
  }

  .search-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    border: 1px solid var(--color-line);
    border-radius: 6px;
    background: var(--color-bg);
    color: var(--color-muted);
    cursor: pointer;
    transition:
      color 0.2s,
      background 0.2s,
      border-color 0.2s;
  }

  .search-toggle:hover {
    color: var(--color-ink);
    background: var(--color-panel);
    border-color: var(--color-ink);
  }

  .site-search-dialog {
    margin-top: 4rem;
    margin-bottom: auto;
    width: min(640px, calc(100vw - 2rem));
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
    padding: 1rem;
    background: var(--color-bg);
    border: 1px solid var(--color-line);
    border-radius: 8px;
    box-shadow: 0 20px 60px color-mix(in srgb, var(--color-ink), transparent 80%);
  }

  .site-search-dialog::backdrop {
    background: color-mix(in srgb, var(--color-ink), transparent 65%);
  }

  .site-search-inner {
    --pagefind-ui-primary: var(--color-accent);
    --pagefind-ui-text: var(--color-ink);
    --pagefind-ui-background: var(--color-bg);
    --pagefind-ui-border: var(--color-line);
    --pagefind-ui-tag: var(--color-panel);
    --pagefind-ui-font: inherit;
  }
</style>

<script>
  import { getLocaleFromUrl, getT } from "../i18n/index";
  import type { A11yTextSize } from "../lib/a11y-settings";
  import { initA11yMenu } from "../lib/a11y-settings";
  import { initLangToggle } from "../lib/i18n-toggle";

  const locale = getLocaleFromUrl(new URL(window.location.href));
  const t = getT(locale);

  const TEXT_SIZE_KEYS: Record<A11yTextSize, Parameters<typeof t>[0]> = {
    normal: "a11y.text_size.normal",
    large: "a11y.text_size.large",
    "extra-large": "a11y.text_size.extra_large",
    "xx-large": "a11y.text_size.xx_large",
  };

  initA11yMenu({
    toggleSelector: ".a11y-toggle",
    menuId: "a11y-menu",
    messages: {
      reducedMotion: {
        on: t("a11y.live.reduced_motion_on"),
        off: t("a11y.live.reduced_motion_off"),
      },
      highContrast: { on: t("a11y.live.high_contrast_on"), off: t("a11y.live.high_contrast_off") },
      textSpacing: { on: t("a11y.live.text_spacing_on"), off: t("a11y.live.text_spacing_off") },
      textSize: (size: A11yTextSize) =>
        t("a11y.live.text_size").replace("{size}", t(TEXT_SIZE_KEYS[size])),
    },
  });
  initLangToggle({ buttonSelector: ".lang-toggle", currentLocale: locale });

  const searchBtn = document.getElementById("site-search-btn") as HTMLButtonElement | null;
  const searchDialog = document.getElementById("site-search-dialog") as HTMLDialogElement | null;
  const searchUi = document.getElementById("site-search-ui") as HTMLElement | null;
  let searchInitialized = false;

  async function openSearch(): Promise<void> {
    if (!searchDialog || !searchUi) return;
    if (!searchInitialized) {
      searchInitialized = true;
      try {
        const link = document.createElement("link");
        link.rel = "stylesheet";
        link.href = "/pagefind/pagefind-ui.css";
        document.head.appendChild(link);
        // @ts-expect-error pagefind-ui.js is generated at build time and not resolvable at type-check time
        const { PagefindUI } = await import("/pagefind/pagefind-ui.js");
        new PagefindUI({ element: searchUi, showSubResults: true, resetStyles: false });
      } catch {
        searchUi.textContent = searchUi.dataset.notBuiltMsg ?? "";
      }
    }
    searchDialog.showModal();
    (searchUi.querySelector("input") as HTMLInputElement | null)?.focus();
  }

  searchBtn?.addEventListener("click", openSearch);
  searchDialog?.addEventListener("click", (e: MouseEvent) => {
    if (e.target === searchDialog) searchDialog.close();
  });
  document.addEventListener("keydown", (e: KeyboardEvent) => {
    if ((e.ctrlKey || e.metaKey) && e.key === "k") {
      e.preventDefault();
      openSearch();
    }
  });
</script>
