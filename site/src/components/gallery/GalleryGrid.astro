---
import { getT, interpolate, type Locale, type DictionaryKeys } from "../../i18n/index";
import GalleryCard from "./GalleryCard.astro";

interface Props {
  samples: Array<{
    id: string;
    title: string;
    description: string;
    tags: string[];
    source: string;
  }>;
  locale: Locale;
}

const { samples, locale } = Astro.props;
const t = getT(locale);

// 全サンプルのタグを出現順・重複排除で集約し、filter チップの並びにする
const allTags: string[] = [];
for (const sample of samples) {
  for (const tag of sample.tags) {
    if (!allTags.includes(tag)) allTags.push(tag);
  }
}
---

<section class="section gallery-section" aria-labelledby="gallery-heading">
  <div class="section-header">
    <h2 id="gallery-heading">{t("gallery.section.heading")}</h2>
    <p>{interpolate(t("gallery.section.count"), { count: String(samples.length) })}</p>
  </div>

  {/* filter bar は JS で hidden を外して有効化する。no-JS では非表示のまま全カードが見える */}
  <div class="gallery-filter" role="group" aria-label={t("gallery.filter.aria_label")} hidden>
    <span class="gallery-filter-label" aria-hidden="true">{t("gallery.filter.label")}</span>
    <button type="button" class="gallery-filter-chip" data-filter-all aria-pressed="true">
      {t("gallery.filter.all")}
    </button>
    {
      allTags.map((tag) => (
        <button
          type="button"
          class="gallery-filter-chip"
          data-filter-tag={tag}
          aria-pressed="false"
        >
          {t(`gallery.tag.${tag}` as DictionaryKeys)}
        </button>
      ))
    }
  </div>
  <p class="gallery-filter-status" data-filter-status aria-live="polite" hidden></p>

  <label class="gallery-labels-toggle">
    <input type="checkbox" data-gallery-show-event-labels-toggle />
    <span>{t("gallery.toolbar.show_event_labels")}</span>
  </label>

  <div class="gallery-grid">
    {samples.map((sample) => <GalleryCard sample={sample} locale={locale} />)}
  </div>

  {
    /* 全カード共有の拡大表示モーダル(#481)。native <dialog>.showModal() で
     フォーカストラップ・Esc クローズ・トップレイヤー表示を無料で得る
     (SiteHeader のモバイルナビ disclosure と同じパターン)。 */
  }
  <dialog class="gallery-preview-dialog" id="gallery-preview-dialog">
    <div class="gallery-preview-dialog-inner">
      <button
        type="button"
        class="gallery-preview-dialog-close"
        id="gallery-preview-dialog-close"
        aria-label={t("gallery.preview_modal.close_aria_label")}
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      <h2 class="gallery-preview-dialog-title" id="gallery-preview-dialog-title"></h2>
      <div class="gallery-preview-dialog-content" id="gallery-preview-dialog-content"></div>
    </div>
  </dialog>
</section>

<style>
  .gallery-section {
    padding-bottom: 4rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 520px), 1fr));
    gap: 2rem;
  }

  .gallery-filter {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .gallery-filter-label {
    margin-right: 0.25rem;
    font-size: var(--text-2xs);
    color: var(--color-muted);
  }

  .gallery-filter-chip {
    padding: 0.3em 0.85em;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    background: var(--color-bg);
    color: var(--color-muted);
    font-family: inherit;
    font-size: var(--text-2xs);
    cursor: pointer;
    transition:
      background 0.15s,
      color 0.15s,
      border-color 0.15s;
  }

  .gallery-filter-chip:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* 選択は背景色に加え font-weight でも示し、high-contrast でも色のみに依存しない */
  .gallery-filter-chip[aria-pressed="true"] {
    border-color: var(--color-accent-strong);
    background: var(--color-accent);
    color: var(--color-on-accent);
    font-weight: 700;
  }

  .gallery-filter-chip:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .gallery-filter-status {
    margin: 0 0 1rem;
    font-size: var(--text-xs);
    color: var(--color-muted);
  }

  .gallery-labels-toggle {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0 0 1.5rem;
    color: var(--color-muted);
    font-size: var(--text-xs);
    font-weight: 650;
    cursor: pointer;
  }

  .gallery-labels-toggle input[type="checkbox"] {
    width: 1.1rem;
    height: 1.1rem;
    accent-color: var(--color-accent);
    cursor: pointer;
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery-filter-chip {
      transition: none;
    }
  }

  :root[data-a11y-reduced-motion="true"] .gallery-filter-chip {
    transition: none;
  }

  .gallery-preview-dialog {
    margin: auto;
    width: min(90vw, 1100px);
    max-height: calc(100vh - 4rem);
    padding: 0;
    background: transparent;
    border: none;
  }

  .gallery-preview-dialog::backdrop {
    background: color-mix(in srgb, var(--color-ink), transparent 65%);
  }

  .gallery-preview-dialog-inner {
    position: relative;
    max-height: calc(100vh - 4rem);
    padding: 1.5rem;
    overflow: auto;
    background: var(--color-bg);
    border: 1px solid var(--color-line);
    border-radius: 10px;
    box-shadow: 0 20px 60px var(--shadow-color-strong);
  }

  .gallery-preview-dialog-close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-pill);
    background: var(--color-bg);
    color: var(--color-muted);
    cursor: pointer;
  }

  .gallery-preview-dialog-close:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .gallery-preview-dialog-close:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .gallery-preview-dialog-title {
    margin: 0 2.5rem 1rem 0;
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 760;
    color: var(--color-ink);
  }

  .gallery-preview-dialog-content {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gallery-preview-dialog-content :global(svg) {
    max-width: 100%;
    height: auto;
  }
</style>
