---
import { getT, localizedPath, type Locale } from "../../i18n/index";
import { getUseCases } from "../../data/lp-content";
import "../../styles/lp/usecases.css";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getT(locale);

const useCases = getUseCases(locale);
---

<section class="section usecase-section" aria-labelledby="usecases-heading">
  <div class="section-header">
    <h2 id="usecases-heading">{t("lp.usecases.heading")}</h2>
    <p>
      {t("lp.usecases.lead")}
    </p>
  </div>
  <div class="usecase-grid">
    {
      useCases.map((useCase) => (
        <article class={`usecase ${useCase.tone}`}>
          <div class="usecase-map" aria-hidden="true">
            <div class="usecase-map-head">
              <span>{useCase.range}</span>
            </div>
            {useCase.map.map((item) => (
              <div
                class={`usecase-bar ${item.tone}`}
                style={`--start: ${item.start}; --width: ${item.width};`}
              >
                <span class="usecase-year">{item.year}</span>
                <span class="usecase-label">{item.label}</span>
              </div>
            ))}
          </div>
          <div>
            <p class="usecase-sample">{useCase.sample}</p>
            <h3>{useCase.title}</h3>
            <p>{useCase.body}</p>
          </div>
        </article>
      ))
    }
  </div>
  <p class="usecase-showcase-link">
    <a href={localizedPath("/showcase/", locale)}>{t("lp.usecase.see_showcase")}</a>
  </p>
</section>
