---
import { Code } from "astro:components";
import { getT, type Locale } from "../../i18n/index";
import { latest } from "../../data/releases";
import { stargazersCount, licenseSpdxId, contributorsCount } from "../../data/repo-stats";
import { formatDate } from "../../lib/site";
import { tdslLang, tdslCodeThemes } from "../../lib/tdsl-shiki";
import { renderSvgFromSource } from "../../lib/tdsl-wasm-node.mts";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getT(locale);
const latestLabel = latest?.tagName || t("lp.hero.latest_label_fallback");
const latestName = latest?.name || latest?.tagName || t("lp.hero.latest_name_fallback");
const shouldShowLatestName = latestName !== latestLabel;

const latestPublishedAt = formatDate(latest?.publishedAt, locale);
const heroDslExample = t("lp.hero.dsl_example");
// Hero の preview は editor パネルと同じ heroDslExample から本体 WASM でビルド時に
// レンダリングする（#428）。DSL が壊れていればここで例外が飛び astro build が失敗するため、
// editor サンプルと preview の乖離はビルドで検知される（DESIGN.md §1 Source as truth）。
// hero の preview は `.timeline-preview` 全体が aria-hidden（装飾扱い、情報は editor パネルと
// 右側のコピーで既に伝えている）。WASM 出力は Playground / Gallery 向けに
// tabindex="0" でツールチップのフォーカスターゲットを持つが、aria-hidden 配下では
// フォーカス可能要素が禁止される（axe: aria-hidden-focus）ため、この埋め込み先限定で除去する。
const heroTimelineSvg = (await renderSvgFromSource(heroDslExample, 0)).replace(
  / tabindex="0"/g,
  "",
);
const starsFormatted =
  typeof stargazersCount === "number"
    ? new Intl.NumberFormat(locale === "ja" ? "ja-JP" : "en-US").format(stargazersCount)
    : null;
const vscodeMarketplaceUrl =
  "https://marketplace.visualstudio.com/items?itemName=keroway.timeline-dsl";
import "../../styles/lp/hero.css";
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-copy">
      <p class="eyebrow">{t("lp.hero.eyebrow")}</p>
      <h1>Timeline DSL</h1>
      <p class="lead">
        {t("lp.hero.lead")}
      </p>
      <div class="actions">
        <a class="button button-primary" href={locale === "ja" ? "/playground/" : "/en/playground/"}
          >{t("cta.try_playground")}</a
        >
        <a class="button button-secondary" href={locale === "ja" ? "/docs/" : "/en/docs/"}
          >{t("cta.view_docs")}</a
        >
      </div>
      <div class="release-summary" aria-label={t("lp.hero.latest_release_aria")}>
        <span class="release-label">{t("lp.hero.latest_release_label")}</span>
        <strong>{latestLabel}</strong>
        {shouldShowLatestName && <span>{latestName}</span>}
        {latestPublishedAt && <time datetime={latest?.publishedAt}>{latestPublishedAt}</time>}
        {latest?.url && <a href={latest.url}>{t("cta.release_notes")}</a>}
      </div>
      <ul class="trust-bar" aria-label={t("lp.hero.trust_bar_aria")}>
        <li class="trust-item">
          <a href="https://github.com/keroway/timeline-dsl">
            <span class="trust-label">{t("lp.hero.trust.stars_label")}</span>
            <strong>{starsFormatted ?? t("lp.hero.trust.stars_fallback")}</strong>
          </a>
        </li>
        {
          licenseSpdxId && (
            <li class="trust-item">
              <span class="trust-label">{t("lp.hero.trust.license_label")}</span>
              <strong>{licenseSpdxId}</strong>
            </li>
          )
        }
        {
          typeof contributorsCount === "number" && contributorsCount > 0 && (
            <li class="trust-item">
              <span class="trust-label">{t("lp.hero.trust.contributors_label")}</span>
              <strong>{contributorsCount}</strong>
            </li>
          )
        }
        <li class="trust-item">
          <a href={vscodeMarketplaceUrl}>
            <span class="trust-label">{t("lp.hero.trust.vscode_label")}</span>
            <strong>VS Code</strong>
          </a>
        </li>
      </ul>
    </div>
    <div class="hero-visual" aria-label={t("lp.hero.workflow_preview_aria")}>
      <div class="editor-panel">
        <div class="panel-bar">
          <span>world-history.tdsl</span>
          <span>{t("lp.hero.panel_bar.validated")}</span>
        </div>
        <Code
          class="code-sample"
          code={heroDslExample}
          lang={tdslLang}
          themes={tdslCodeThemes}
          defaultColor={false}
        />
      </div>
      <div class="timeline-preview" aria-hidden="true">
        <div class="preview-header">
          <span>{t("lp.hero.preview_header")}</span>
          <span>980 - 1260</span>
        </div>
        {/* 本体 WASM が生成した信頼済み SVG（editor パネルと同一ソースから導出、#428） */}
        <div class="timeline-svg-wrap" set:html={heroTimelineSvg} />
      </div>
      <div class="command-strip" aria-hidden="true">
        <span class="prompt">$</span>
        <span class="command-strip__command">tdsl check world-history.tdsl</span>
        <strong class="command-strip__result">0 errors</strong>
      </div>
    </div>
  </div>
</section>
