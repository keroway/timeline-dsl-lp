---
import { getT, type Locale } from "../../i18n/index";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getT(locale);
---

<div class="playground-panel preview-workbench">
  <div class="playground-panel-bar">
    <span>preview.svg</span>
    <span data-preview-meta>{t("playground.preview.waiting")}</span>
  </div>
  <div class="preview-surface" data-smoke="playground-preview" data-preview>
    <div class="pan-zoom-stage" data-pan-zoom-stage>
      <p class="pan-zoom-placeholder">{t("playground.preview.placeholder")}</p>
    </div>
    <button
      class="pan-zoom-reset"
      type="button"
      data-pan-zoom-reset
      aria-label={t("playground.preview.reset_aria")}
      title={t("playground.preview.reset_title")}
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <polyline points="15 3 21 3 21 9"></polyline>
        <polyline points="9 21 3 21 3 15"></polyline>
        <line x1="21" y1="3" x2="14" y2="10"></line>
        <line x1="3" y1="21" x2="10" y2="14"></line>
      </svg>
    </button>
  </div>
</div>
