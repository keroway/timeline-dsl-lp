---
/**
 * Starlight `components.SocialIcons` override for Docs pages.
 *
 * Renders the GitHub social link (from Starlight config) and the shared
 * a11y settings toggle (reduced-motion / high-contrast / text-size) so the
 * Docs header offers the same accessibility menu as the LP / Playground /
 * Changelog pages that use SiteHeader.astro directly.
 *
 * The toggle button and dropdown are self-contained in this component.
 * Starlight's sidebar, search, and mobile-menu functions are untouched.
 */
import config from "virtual:starlight/user-config";
import { Icon } from "@astrojs/starlight/components";

const links = config.social ?? [];
---

{
  links.length > 0 &&
    links.map(({ label, href, icon }) => (
      <a {href} rel="me" class="sl-flex social-link">
        <span class="sr-only">{label}</span>
        <Icon name={icon} />
      </a>
    ))
}

<div class="a11y-wrap">
  <button
    class="a11y-toggle"
    type="button"
    aria-expanded="false"
    aria-controls="docs-a11y-menu"
    aria-label="アクセシビリティ設定"
  >
    <svg
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <circle cx="12" cy="12" r="10"></circle>
      <line x1="12" y1="8" x2="12" y2="16"></line>
      <line x1="8" y1="12" x2="16" y2="12"></line>
    </svg>
  </button>

  <div id="docs-a11y-menu" class="a11y-menu" hidden>
    <div class="a11y-menu-inner">
      <div class="a11y-section">
        <h3>視覚効果・動き</h3>
        <div class="a11y-field">
          <label>
            <input type="checkbox" data-a11y-reduced-motion />
            動きを抑える (Reduced motion)
          </label>
        </div>
        <div class="a11y-field">
          <label>
            <input type="checkbox" data-a11y-high-contrast />
            高コントラスト表示
          </label>
        </div>
      </div>
      <div class="a11y-section">
        <h3>文字サイズ</h3>
        <div class="a11y-field">
          <select data-a11y-text-size>
            <option value="normal">標準</option>
            <option value="large">大きく</option>
            <option value="extra-large">さらに大きく</option>
          </select>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .social-link {
    color: var(--sl-color-text-accent);
    padding: 0.5em;
    margin: -0.5em;
  }
  .social-link:hover {
    color: var(--sl-color-white);
  }

  .a11y-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  .a11y-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 6px;
    background: transparent;
    color: var(--sl-color-text-accent);
    cursor: pointer;
    transition: all 0.2s;
  }

  .a11y-toggle:hover {
    color: var(--sl-color-white);
    background: var(--sl-color-gray-6);
    border-color: var(--sl-color-gray-4);
  }

  .a11y-toggle[aria-expanded="true"] {
    background: var(--sl-color-gray-6);
    color: var(--sl-color-text-accent);
    border-color: var(--sl-color-text-accent);
  }

  .a11y-menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    width: min(320px, 90vw);
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-gray-5);
    box-shadow: var(--sl-shadow-lg);
    z-index: 200;
    border-radius: 6px;
  }

  .a11y-menu:not([hidden]) {
    display: block;
  }

  .a11y-menu-inner {
    padding: 1.25rem;
  }

  .a11y-section + .a11y-section {
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--sl-color-gray-5);
  }

  .a11y-section h3 {
    margin: 0 0 0.75rem;
    font-size: 0.85rem;
    color: var(--sl-color-gray-2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .a11y-field {
    margin: 0.5rem 0;
  }

  .a11y-field label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    cursor: pointer;
    color: var(--sl-color-text);
  }

  .a11y-field select {
    width: 100%;
    height: 2.25rem;
    padding: 0 0.5rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 4px;
    background: var(--sl-color-bg);
    color: var(--sl-color-text);
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>(".a11y-toggle");
  const menu = document.getElementById("docs-a11y-menu");
  const reducedMotion = document.querySelector<HTMLInputElement>(
    "[data-a11y-reduced-motion]"
  );
  const highContrast = document.querySelector<HTMLInputElement>(
    "[data-a11y-high-contrast]"
  );
  const textSize =
    document.querySelector<HTMLSelectElement>("[data-a11y-text-size]");

  const SETTINGS_KEY = "tdsl-a11y-settings";

  interface Settings {
    reducedMotion: boolean;
    highContrast: boolean;
    textSize: string;
  }

  const loadSettings = (): Settings => {
    const saved = localStorage.getItem(SETTINGS_KEY);
    if (saved) {
      try {
        return JSON.parse(saved);
      } catch (e) {
        // ignore
      }
    }
    return {
      reducedMotion: window.matchMedia("(prefers-reduced-motion: reduce)")
        .matches,
      highContrast: window.matchMedia("(prefers-contrast: more)").matches,
      textSize: "normal",
    };
  };

  const saveSettings = (settings: Settings) => {
    localStorage.setItem(SETTINGS_KEY, JSON.stringify(settings));
    applySettings(settings);
  };

  const applySettings = (settings: Settings) => {
    const root = document.documentElement;

    if (settings.reducedMotion) {
      root.setAttribute("data-a11y-reduced-motion", "true");
    } else {
      root.removeAttribute("data-a11y-reduced-motion");
    }

    if (settings.highContrast) {
      root.setAttribute("data-a11y-contrast", "high");
    } else {
      root.removeAttribute("data-a11y-contrast");
    }

    root.setAttribute("data-a11y-text-size", settings.textSize);

    if (reducedMotion) reducedMotion.checked = settings.reducedMotion;
    if (highContrast) highContrast.checked = settings.highContrast;
    if (textSize) textSize.value = settings.textSize;
  };

  const currentSettings = loadSettings();
  applySettings(currentSettings);

  toggle?.addEventListener("click", () => {
    const expanded = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!expanded));
    if (menu) menu.hidden = expanded;
  });

  document.addEventListener("click", (e) => {
    if (
      menu &&
      !menu.hidden &&
      !toggle?.contains(e.target as Node) &&
      !menu.contains(e.target as Node)
    ) {
      toggle?.setAttribute("aria-expanded", "false");
      menu.hidden = true;
    }
  });

  reducedMotion?.addEventListener("change", () => {
    const s = loadSettings();
    s.reducedMotion = reducedMotion.checked;
    saveSettings(s);
  });

  highContrast?.addEventListener("change", () => {
    const s = loadSettings();
    s.highContrast = highContrast.checked;
    saveSettings(s);
  });

  textSize?.addEventListener("change", () => {
    const s = loadSettings();
    s.textSize = textSize.value;
    saveSettings(s);
  });
</script>
