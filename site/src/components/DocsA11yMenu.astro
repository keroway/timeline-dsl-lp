---
/**
 * Starlight `components.SocialIcons` override for Docs pages.
 *
 * Renders the GitHub social link (from Starlight config) and the shared
 * a11y settings toggle (reduced-motion / high-contrast / text-size) so the
 * Docs header offers the same accessibility menu as the LP / Playground /
 * Changelog pages that use SiteHeader.astro directly.
 *
 * The toggle button and dropdown are self-contained in this component.
 * Starlight's sidebar, search, and mobile-menu functions are untouched.
 */
import config from "virtual:starlight/user-config";
import { Icon } from "@astrojs/starlight/components";
import { getT, resolveLocale } from "../i18n/index";
import A11yMenuPanel from "./A11yMenuPanel.astro";

const links = config.social ?? [];
const locale = resolveLocale(Astro);
const t = getT(locale);
const targetLocaleLabel = locale === "ja" ? "EN" : "JP";
---

{
  links.length > 0 &&
    links.map(({ label, href, icon }) => (
      <a {href} rel="me" class="sl-flex social-link">
        <span class="sr-only">{label}</span>
        <Icon name={icon} />
      </a>
    ))
}

<div class="a11y-wrap">
  <button
    class="lang-toggle docs-lang-toggle"
    type="button"
    aria-label={t("nav.lang_toggle.aria_label")}>{targetLocaleLabel}</button
  >
  <A11yMenuPanel menuId="docs-a11y-menu" locale={locale} langToggleSelector=".docs-lang-toggle" />
</div>

<style>
  .social-link {
    color: var(--sl-color-text-accent);
    padding: 0.5em;
    margin: -0.5em;
  }
  .social-link:hover {
    color: var(--sl-color-white);
  }

  .a11y-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    --a11y-toggle-bg: transparent;
    --a11y-bg: var(--sl-color-bg);
    --a11y-line: var(--sl-color-gray-5);
    --a11y-text: var(--sl-color-text);
    --a11y-muted: var(--sl-color-gray-2);
    --a11y-panel: var(--sl-color-gray-6);
    --a11y-accent: var(--sl-color-text-accent);
    --a11y-accent-strong: var(--sl-color-white);
    --a11y-shadow: var(--sl-shadow-lg);
    --a11y-menu-top: calc(100% + 0.5rem);
    --a11y-menu-border-top: 1px solid var(--sl-color-gray-5);
    --a11y-menu-radius: 6px;
    --a11y-menu-z: 200;
  }

  .docs-lang-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    height: 2.5rem;
    padding: 0 0.5rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 6px;
    background: transparent;
    color: var(--sl-color-text-accent);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: all 0.2s;
  }

  .docs-lang-toggle:hover {
    color: var(--sl-color-white);
    background: var(--sl-color-gray-6);
    border-color: var(--sl-color-gray-4);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
