---
/**
 * Starlight `components.SocialIcons` override for Docs pages.
 *
 * Renders the GitHub social link (from Starlight config) and the shared
 * a11y settings toggle (reduced-motion / high-contrast / text-size) so the
 * Docs header offers the same accessibility menu as the LP / Playground /
 * Changelog pages that use SiteHeader.astro directly.
 *
 * The toggle button and dropdown are self-contained in this component.
 * Starlight's sidebar, search, and mobile-menu functions are untouched.
 */
import config from "virtual:starlight/user-config";
import { Icon } from "@astrojs/starlight/components";
import { getT, type Locale } from "../i18n/index";

const links = config.social ?? [];
const locale = (Astro.currentLocale ?? "ja") as Locale;
const t = getT(locale);
const targetLocaleLabel = locale === "ja" ? "EN" : "JP";
---

{
  links.length > 0 &&
    links.map(({ label, href, icon }) => (
      <a {href} rel="me" class="sl-flex social-link">
        <span class="sr-only">{label}</span>
        <Icon name={icon} />
      </a>
    ))
}

<div class="a11y-wrap">
  <button
    class="lang-toggle docs-lang-toggle"
    type="button"
    aria-label={t("nav.lang_toggle.aria_label")}>{targetLocaleLabel}</button
  >
  <button
    class="a11y-toggle"
    type="button"
    aria-haspopup="menu"
    aria-expanded="false"
    aria-controls="docs-a11y-menu"
    aria-label={t("a11y.menu.toggle_aria_label")}
  >
    <svg
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <circle cx="12" cy="12" r="10"></circle>
      <line x1="12" y1="8" x2="12" y2="16"></line>
      <line x1="8" y1="12" x2="16" y2="12"></line>
    </svg>
  </button>

  <div id="docs-a11y-menu" class="a11y-menu" hidden>
    <div class="a11y-menu-inner">
      <div class="a11y-section">
        <h3>{t("a11y.section.visual")}</h3>
        <div class="a11y-field">
          <label>
            <input type="checkbox" data-a11y-reduced-motion />
            {t("a11y.field.reduced_motion")}
          </label>
        </div>
        <div class="a11y-field">
          <label>
            <input type="checkbox" data-a11y-high-contrast />
            {t("a11y.field.high_contrast")}
          </label>
        </div>
      </div>
      <div class="a11y-section">
        <h3>{t("a11y.section.readability")}</h3>
        <div class="a11y-field">
          <label>
            <input type="checkbox" data-a11y-text-spacing-input />
            {t("a11y.field.text_spacing")}
          </label>
        </div>
        <div class="a11y-field">
          <select data-a11y-text-size>
            <option value="normal">{t("a11y.text_size.normal")}</option>
            <option value="large">{t("a11y.text_size.large")}</option>
            <option value="extra-large">{t("a11y.text_size.extra_large")}</option>
            <option value="xx-large">{t("a11y.text_size.xx_large")}</option>
          </select>
        </div>
      </div>
      <div class="sr-only" aria-live="polite" data-a11y-live></div>
    </div>
  </div>
</div>

<style>
  .social-link {
    color: var(--sl-color-text-accent);
    padding: 0.5em;
    margin: -0.5em;
  }
  .social-link:hover {
    color: var(--sl-color-white);
  }

  .a11y-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .docs-lang-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    height: 2.5rem;
    padding: 0 0.5rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 6px;
    background: transparent;
    color: var(--sl-color-text-accent);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: all 0.2s;
  }

  .docs-lang-toggle:hover {
    color: var(--sl-color-white);
    background: var(--sl-color-gray-6);
    border-color: var(--sl-color-gray-4);
  }

  .a11y-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 6px;
    background: transparent;
    color: var(--sl-color-text-accent);
    cursor: pointer;
    transition: all 0.2s;
  }

  .a11y-toggle:hover {
    color: var(--sl-color-white);
    background: var(--sl-color-gray-6);
    border-color: var(--sl-color-gray-4);
  }

  .a11y-toggle[aria-expanded="true"] {
    background: var(--sl-color-gray-6);
    color: var(--sl-color-text-accent);
    border-color: var(--sl-color-text-accent);
  }

  .a11y-menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    width: min(320px, 90vw);
    max-height: calc(100vh - 5rem);
    overflow-y: auto;
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-gray-5);
    box-shadow: var(--sl-shadow-lg);
    z-index: 200;
    border-radius: 6px;
  }

  .a11y-menu:not([hidden]) {
    display: block;
  }

  .a11y-menu-inner {
    padding: 1.25rem;
  }

  .a11y-section + .a11y-section {
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--sl-color-gray-5);
  }

  .a11y-section h3 {
    margin: 0 0 0.75rem;
    font-size: 0.85rem;
    color: var(--sl-color-gray-2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .a11y-field {
    margin: 0.5rem 0;
  }

  .a11y-field label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    cursor: pointer;
    color: var(--sl-color-text);
  }

  .a11y-field select {
    width: 100%;
    height: 2.25rem;
    padding: 0 0.5rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 4px;
    background: var(--sl-color-bg);
    color: var(--sl-color-text);
  }
</style>

<script>
  import { getLocaleFromUrl, getT } from "../i18n/index";
  import type { A11yTextSize } from "../lib/a11y-settings";
  import { initA11yMenu } from "../lib/a11y-settings";
  import { initLangToggle } from "../lib/i18n-toggle";

  const locale = getLocaleFromUrl(new URL(window.location.href));
  const t = getT(locale);

  const TEXT_SIZE_KEYS: Record<A11yTextSize, Parameters<typeof t>[0]> = {
    normal: "a11y.text_size.normal",
    large: "a11y.text_size.large",
    "extra-large": "a11y.text_size.extra_large",
    "xx-large": "a11y.text_size.xx_large",
  };

  initA11yMenu({
    toggleSelector: ".a11y-toggle",
    menuId: "docs-a11y-menu",
    messages: {
      reducedMotion: {
        on: t("a11y.live.reduced_motion_on"),
        off: t("a11y.live.reduced_motion_off"),
      },
      highContrast: { on: t("a11y.live.high_contrast_on"), off: t("a11y.live.high_contrast_off") },
      textSpacing: { on: t("a11y.live.text_spacing_on"), off: t("a11y.live.text_spacing_off") },
      textSize: (size: A11yTextSize) =>
        t("a11y.live.text_size").replace("{size}", t(TEXT_SIZE_KEYS[size])),
    },
  });
  initLangToggle({ buttonSelector: ".docs-lang-toggle", currentLocale: locale });
</script>
